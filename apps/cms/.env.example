# Strapi Environment Configuration for GROUPE CERIN CMS
# Copy this file to .env and adjust values for each environment

# ==============================================
# DATABASE CONFIGURATION
# ==============================================
DATABASE_HOST=localhost
DATABASE_PORT=3307
DATABASE_NAME=cerin_cms
DATABASE_USERNAME=cerin_cms
DATABASE_PASSWORD=change_me_in_production

# ==============================================
# APPLICATION SECRETS
# ==============================================
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
APP_KEYS=replace_with_generated_app_key_1,replace_with_generated_app_key_2,replace_with_generated_app_key_3,replace_with_generated_app_key_4

# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
API_TOKEN_SALT=replace_with_generated_api_token_salt

# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
ADMIN_JWT_SECRET=replace_with_generated_admin_jwt_secret

# JWT Secret for public API
JWT_SECRET=replace_with_generated_jwt_secret

# ==============================================
# SERVER CONFIGURATION
# ==============================================
HOST=localhost
PORT=1337

# URL used by Strapi for links in emails, etc.
URL=http://localhost:1337

# ==============================================
# SECURITY
# ==============================================
# CORS allowed origins (comma-separated for production)
CORS_ORIGIN=http://localhost:4321,http://localhost:3000

# IP rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ==============================================
# UPLOAD / MEDIA
# ==============================================
UPLOAD_MAX_FILE_SIZE=20971520
UPLOAD_MAX_IMAGE_UPLOAD=20971520

# ==============================================
# LOGGING
# ==============================================
LOG_LEVEL=info

# ==============================================
# EMAIL PROVIDER (configure for production)
# ==============================================
# SMTP provider: sendgrid, mailgun, ses, etc.
SMTP_HOST=
SMTP_PORT=
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_SECURE=false
DEFAULT_FROM_EMAIL=noreply@groupe-cerin.com

# ==============================================
# ENVIRONMENT
# ==============================================
NODE_ENV=development
