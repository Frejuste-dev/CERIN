{
  "kind": "collectionType",
  "collectionName": "programs",
  "info": {
    "singularName": "program",
    "pluralName": "programs",
    "displayName": "Program",
    "description": "Formations et programmes du Groupe CERIN"
  },
  "options": {
    "draftAndPublish": true,
    "timestamps": true
  },
  "attributes": {
    "title": {
      "type": "text",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true,
      "unique": true
    },
    "category": {
      "type": "enumeration",
      "enum": ["GENERAL", "TECHNIQUE", "SUPERIEUR"],
      "required": true
    },
    "level": {
      "type": "string",
      "required": true
    },
    "duration": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "text",
      "required": true
    },
    "objectives": {
      "type": "text"
    },
    "curriculum": {
      "type": "text"
    },
    "career_opportunities": {
      "type": "text"
    },
    "admission_requirements": {
      "type": "text"
    },
    "tuition": {
      "type": "string"
    },
    "image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images", "files"]
    },
    "featured": {
      "type": "boolean",
      "default": false
    },
    "published_at": {
      "type": "datetime",
      "default": "now"
    },
    "seo_title": {
      "type": "string"
    },
    "seo_description": {
      "type": "text"
    },
    "canonical_url": {
      "type": "string"
    },
    "og_image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    }
  }
}
