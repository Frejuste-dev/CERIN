# ===================================
# CERIN Server — Environment Variables
# ===================================

# Server
NODE_ENV=production
PORT=8080

# Database (Railway MySQL)
DB_HOST=PLACEHOLDER
DB_PORT=3306
DB_NAME=cerin_db
DB_USER=PLACEHOLDER
DB_PASSWORD=PLACEHOLDER

# CORS (Firebase Hosting domain)
CORS_ORIGIN=https://cerin-group.web.app

# Admin Security
ADMIN_API_KEY=PLACEHOLDER_REPLACE_WITH_RANDOM

# Firebase Admin SDK (for Storage)
FIREBASE_PROJECT_ID=PLACEHOLDER
FIREBASE_CLIENT_EMAIL=PLACEHOLDER
FIREBASE_PRIVATE_KEY=PLACEHOLDER
FIREBASE_STORAGE_BUCKET=PLACEHOLDER.appspot.com
