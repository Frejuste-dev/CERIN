# ==============================================
# CERIN Server — Environment Variables Example
# ==============================================
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# ─── Server ───────────────────────────────────
NODE_ENV=development
PORT=3001

# ─── MySQL Database ───────────────────────────
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=REPLACE_WITH_DB_PASSWORD
DB_NAME=cerin_db

# ─── Admin API Key ────────────────────────────
# Protects GET /api/candidatures (list & detail).
# POST /api/candidatures remains public.
#
# How to use in requests:
#   Authorization: Bearer YOUR_KEY_HERE
#
# How to generate a new key (Node.js):
#   node -e "const c=require('crypto'); console.log(c.randomBytes(32).toString('base64url'));"
#
# Add to GitHub Secrets as ADMIN_API_KEY before production deployment.
ADMIN_API_KEY=PLACEHOLDER_REPLACE_WITH_RANDOM_STRING
