---
import { Menu, X, ChevronDown } from "lucide-react";

const navLinks = [
  { label: "Accueil", href: "/" },
    {
      label: "Programmes",
      children: [
        { label: "Enseignement Général", href: "/formations/enseignement-general" },
        { label: "Technique & Professionnel", href: "/formations/enseignement-technique" },
        { label: "Supérieur", href: "/formations/enseignement-superieur" },
      ],
    },
  {
    label: "Vie CERIN",
    children: [
      { label: "À propos", href: "/about" },
      { label: "Vie scolaire", href: "/evenements" },
      { label: "Galerie", href: "/galerie" },
      { label: "Résultats académiques", href: "/resultats" },
    ],
  },
  { label: "Actualités", href: "/actualites" },
  { label: "Offres de recrutement", href: "/offres" },
  { label: "Contact", href: "/contact" },
];

// Active route detection (Astro.url is available in frontmatter)
const currentPath = Astro.url.pathname;

function isActive(href: string) {
  if (href === "/") return currentPath === "/";
  return currentPath.startsWith(href);
}

function isParentActive(children: { href: string }[]) {
  return children.some((child) => currentPath.startsWith(child.href));
}
---

<header
  id="site-header"
  class="fixed top-0 left-0 right-0 z-50 bg-white/90 backdrop-blur-md border-b border-[#E5EDD5] transition-all duration-300 p-2 sm:p-3 lg:p-4"
>
  {/* Skip link — accessibilité clavier */}
  <a
    href="#main-content"
    class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:z-[60] focus:px-4 focus:py-2 focus:bg-[#72CD00] focus:text-white focus:rounded-lg focus:outline-none"
  >
    Aller au contenu principal
  </a>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center justify-between gap-6">
    {/* Logo */}
    <a
      href="/"
      class="flex items-center gap-3 shrink-0 rounded-lg focus:outline-none focus:ring-2 focus:ring-[#72CD00] focus:ring-offset-2"
    >
      <img
        src="/logo.png"
        alt="Logo Groupe CERIN"
        class="h-10 w-auto transition-transform duration-300 hover:scale-105"
        onerror="this.style.display='none'"
      />
    </a>

    {/* Desktop nav */}
    <nav class="hidden lg:flex justify-between items-center gap-6" aria-label="Navigation principale">
      {navLinks.map((link) =>
        link.children ? (
          <div class="relative dropdown-wrapper">
            <button
              type="button"
              class:list={[
                "dropdown-trigger flex items-center justify-between gap-1 px-4 py-2 rounded-lg transition-colors text-sm font-medium focus:outline-none focus:ring-2 focus:ring-[#72CD00] focus:ring-offset-2",
                isParentActive(link.children)
                  ? "text-[#72CD00] bg-green-50"
                  : "text-gray-700 hover:text-[#72CD00] hover:bg-green-50",
              ]}
              aria-expanded="false"
              aria-haspopup="true"
            >
              {link.label}
              <ChevronDown class="dropdown-chevron transition-transform duration-200" size={14}  />
            </button>
            <div class="dropdown-menu absolute top-full left-0 mt-2 bg-white border border-[#E5EDD5] rounded-2xl shadow-[0_8px_32px_rgba(28,51,0,0.12)] p-2 min-w-[220px] z-50 opacity-0 invisible scale-95 transition-all duration-200 origin-top">
              {link.children.map((child) => (
                <a
                  href={child.href}
                  class:list={[
                    "flex items-center gap-3 px-4 py-3 rounded-xl text-[#0B0B0B] font-medium transition-all duration-200 border-l-2 border-transparent focus:outline-none focus:ring-2 focus:ring-inset focus:ring-[#72CD00]",
                    isActive(child.href)
                      ? "bg-[#E8F5D0] text-[#3D6E00] border-[#72CD00]"
                      : "hover:bg-[#E8F5D0] hover:text-[#3D6E00] hover:border-[#72CD00]",
                  ]}
                  aria-current={isActive(child.href) ? "page" : undefined}
                >
                  {child.label}
                </a>
              ))}
            </div>
          </div>
        ) : (
          <a
            href={link.href}
            class:list={[
              "relative font-medium text-[#0B0B0B] hover:text-[#72CD00] transition-colors duration-200 py-1 after:absolute after:bottom-0 after:left-0 after:h-0.5 after:w-0 after:bg-[#72CD00] after:transition-all after:duration-300 hover:after:w-full focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#72CD00] focus-visible:ring-offset-2 rounded-sm",
              isActive(link.href)
                ? "text-[#72CD00] font-semibold after:w-full"
                : "",
            ]}
            aria-current={isActive(link.href) ? "page" : undefined}
          >
            {link.label}
          </a>
        )
      )}
    </nav>

    {/* CTA */}
    <div class="hidden lg:flex items-center gap-3">
      <a
        href="#"
        class="btn-primary text-sm px-5 py-2.5"
      >
        Préinscription
      </a>
      <a
        href="#"
        class="btn-secondary text-sm px-5 py-2.5"
      >
        Scolarité
      </a>
    </div>

    {/* Mobile toggle */}
    <button
      id="mobile-menu-toggle"
      class="lg:hidden p-2 rounded-lg text-gray-700 hover:bg-gray-100 focus:outline-none focus:ring-2 focus:ring-[#72CD00] focus:ring-offset-2"
      aria-label="Ouvrir le menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <Menu size={22} class="menu-icon" />
      <X size={22} class="close-icon hidden" />
    </button>
  </div>

  {/* Mobile menu */}
  <div
    id="mobile-menu"
    class="hidden lg:hidden px-4 py-4 space-y-1 shadow-2xl overflow-y-auto max-h-[calc(100vh-72px)]"
    style="background: linear-gradient(180deg, #1C3300 0%, #0B0B0B 100%)"
  >
    {navLinks.map((link) =>
      link.children ? (
        <div class="py-1">
          <p class="px-3 py-1 text-xs font-semibold text-white/50 uppercase tracking-wider">
            {link.label}
          </p>
          {link.children.map((child) => (
            <a
              href={child.href}
              class:list={[
                "block px-6 py-2.5 text-sm rounded-lg focus:outline-none focus:ring-2 focus:ring-[#72CD00] focus:ring-offset-2",
                isActive(child.href)
                  ? "text-[#FEFF01] font-medium"
                  : "text-white hover:text-[#FEFF01]",
              ]}
              aria-current={isActive(child.href) ? "page" : undefined}
            >
              {child.label}
            </a>
          ))}
        </div>
      ) : (
        <a
          href={link.href}
          class:list={[
            "block px-3 py-2.5 text-sm font-medium rounded-lg focus:outline-none focus:ring-2 focus:ring-[#72CD00] focus:ring-offset-2",
            isActive(link.href)
              ? "text-[#FEFF01]"
              : "text-white hover:text-[#FEFF01]",
          ]}
          aria-current={isActive(link.href) ? "page" : undefined}
        >
          {link.label}
        </a>
      )
    )}
    <div class="pt-3 space-y-2" style="border-top: 1px solid rgba(114,205,0,0.2)">
      <a
        href="#"
        class="btn-primary block w-full text-center"
      >
        Préinscription
      </a>
      <a
        href="#"
        class="btn-secondary block w-full text-center"
      >
        Scolarité
      </a>
    </div>
  </div>
</header>

<script>
  // Mobile menu toggle
  const toggleBtn = document.getElementById("mobile-menu-toggle");
  const mobileMenu = document.getElementById("mobile-menu");
  const menuIcon = toggleBtn?.querySelector(".menu-icon");
  const closeIcon = toggleBtn?.querySelector(".close-icon");

  toggleBtn?.addEventListener("click", () => {
    const isOpen = !mobileMenu?.classList.contains("hidden");
    mobileMenu?.classList.toggle("hidden");
    menuIcon?.classList.toggle("hidden");
    closeIcon?.classList.toggle("hidden");
    toggleBtn.setAttribute("aria-expanded", String(!isOpen));
    toggleBtn.setAttribute("aria-label", isOpen ? "Ouvrir le menu" : "Fermer le menu");
  });

  // Header shadow on scroll
  const header = document.getElementById("site-header");
  window.addEventListener("scroll", () => {
    if (window.scrollY > 20) {
      header?.classList.add("shadow-md");
    } else {
      header?.classList.remove("shadow-md");
    }
  });

  // Click-accessible dropdowns (works on touch/tablet, not just hover)
  const dropdownWrappers = document.querySelectorAll(".dropdown-wrapper");

  dropdownWrappers.forEach((wrapper) => {
    const trigger = wrapper.querySelector(".dropdown-trigger");
    const menu = wrapper.querySelector(".dropdown-menu");
    const chevron = wrapper.querySelector(".dropdown-chevron");

    const openMenu = () => {
      menu?.classList.remove("opacity-0", "invisible", "scale-95");
      menu?.classList.add("opacity-100", "visible", "scale-100");
      chevron?.classList.add("rotate-180");
      trigger?.setAttribute("aria-expanded", "true");
    };

    const closeMenu = () => {
      menu?.classList.add("opacity-0", "invisible", "scale-95");
      menu?.classList.remove("opacity-100", "visible", "scale-100");
      chevron?.classList.remove("rotate-180");
      trigger?.setAttribute("aria-expanded", "false");
    };

    // Hover for mouse users (desktop)
    wrapper.addEventListener("mouseenter", openMenu);
    wrapper.addEventListener("mouseleave", closeMenu);

    // Click for touch/keyboard users
    trigger?.addEventListener("click", (e) => {
      e.stopPropagation();
      const isOpen = trigger.getAttribute("aria-expanded") === "true";
      // Close all other dropdowns first
      dropdownWrappers.forEach((w) => {
        if (w !== wrapper) {
          w.querySelector(".dropdown-menu")?.classList.add("opacity-0", "invisible", "scale-95");
          w.querySelector(".dropdown-menu")?.classList.remove("opacity-100", "visible", "scale-100");
          w.querySelector(".dropdown-trigger")?.setAttribute("aria-expanded", "false");
        }
      });
      isOpen ? closeMenu() : openMenu();
    });
  });

  // Close dropdowns when clicking outside
  document.addEventListener("click", (e) => {
    dropdownWrappers.forEach((wrapper) => {
      if (!wrapper.contains(e.target as Node)) {
        wrapper.querySelector(".dropdown-menu")?.classList.add("opacity-0", "invisible", "scale-95");
        wrapper.querySelector(".dropdown-menu")?.classList.remove("opacity-100", "visible", "scale-100");
        wrapper.querySelector(".dropdown-trigger")?.setAttribute("aria-expanded", "false");
      }
    });
  });

  // Close dropdowns on Escape key
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") {
      dropdownWrappers.forEach((wrapper) => {
        wrapper.querySelector(".dropdown-menu")?.classList.add("opacity-0", "invisible", "scale-95");
        wrapper.querySelector(".dropdown-menu")?.classList.remove("opacity-100", "visible", "scale-100");
        wrapper.querySelector(".dropdown-trigger")?.setAttribute("aria-expanded", "false");
      });
    }
  });
</script>