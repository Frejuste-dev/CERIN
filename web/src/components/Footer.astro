---
import { MapPin, Phone, Mail, Facebook, Instagram, Linkedin, X } from "lucide-react";

const footerLinks = {
  formations: {
    title: "Nos Programmes",
    links: [
      { label: "Enseignement Général", href: "/formations/enseignement-technique" },
      { label: "Technique & Professionnel", href: "/formations/enseignement-technique" },
      { label: "Enseignement Supérieur", href: "/formations/enseignement-superieur" },
      { label: "BTS", href: "/formations/enseignement-superieur" },
      { label: "Licence / Bachelor", href: "/formations/enseignement-superieur" },
      { label: "Master", href: "/formations/enseignement-superieur" },
    ],
  },
  admissions: {
    title: "Admissions",
    links: [
      { label: "Dépôt de candidature", href: "/admissions" },
      { label: "Inscription", href: "/inscription" },
      { label: "Frais de scolarité", href: "/admissions" },
      { label: "Bourses & Aides", href: "/admissions" },
      { label: "FAQ", href: "/admissions" },
    ],
  },
  institution: {
    title: "L'Institution",
    links: [
      { label: "À propos du CERIN", href: "/about" },
      { label: "Vie scolaire", href: "/evenements" },
      { label: "Galerie", href: "/galerie" },
      { label: "Résultats académiques", href: "/resultats" },
      { label: "Actualités", href: "/actualites" },
      { label: "Contact", href: "/contact" },
    ],
  },
};

const socials = [
  { icon: Facebook, href: "https://www.facebook.com/profile.php?id=61572392949647", label: "Facebook" },
  { icon: Instagram, href: "https://www.instagram.com/ceringroup_20214/", label: "Instagram" },
  { icon: Linkedin, href: "https://www.linkedin.com/in/cerin-groupe-937542350/", label: "LinkedIn" },
  { icon: X, href: "https://x.com/groupecerin2014", label: "X" },
];
---

<footer id="contact" style="background: linear-gradient(180deg, #1C3300 0%, #0B0B0B 100%)">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-16 pb-8">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 mb-14">
      {/* Brand col */}
      <div>
        <img
          src="/logo.png"
           alt="Logo Groupe CERIN"
          class="h-12 w-auto mb-4 brightness-0 invert"
          onerror="this.style.display='none'"
        />
        <p class="text-white/70 text-sm leading-relaxed mb-2 font-['Inter',sans-serif]">
          Groupe CERIN
        </p>
        <p class="text-[#72CD00] text-sm italic mb-6 font-['Inter',sans-serif]">
          Former les leaders de demain
        </p>

        <div class="space-y-3 mb-6">
          {[
            { icon: MapPin, text: "Yopougon, face Institut Pasteur, Abidjan, Côte d'Ivoire" },
            { icon: Phone, text: "+225 01 02 55 55 50" },
            { icon: Mail, text: "contact@groupe-cerin.com" },
          ].map(({ icon: Icon, text }) => (
            <div class="flex items-start gap-3 text-sm text-white/70">
              <Icon size={15} class="shrink-0 mt-0.5 text-[#72CD00]" />
              <span class="font-['Inter',sans-serif]">{text}</span>
            </div>
          ))}
        </div>

        <div class="flex gap-3">
          {socials.map(({ icon: Icon, href, label }) => (
            <a
              href={href}
              aria-label={label}
              class="w-10 h-10 rounded-full flex items-center justify-center transition-all hover:scale-110 border border-[#72CD00]/30 hover:bg-[#72CD00] hover:border-[#72CD00]"
              style="background: rgba(114,205,0,0.1)"
            >
              <Icon size={16} class="text-[#72CD00] hover:text-white" />
            </a>
          ))}
        </div>
      </div>

      {/* Links */}
      {Object.values(footerLinks).map((col) => (
        <div>
          <h4 class="text-[#72CD00] uppercase text-xs tracking-widest font-semibold mb-4 font-['Poppins',sans-serif]">
            {col.title}
          </h4>
          <ul class="space-y-2.5">
            {col.links.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-sm text-white/70 hover:text-[#FEFF01] transition-colors font-['Inter',sans-serif]"
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    {/* Bottom bar */}
    <div class="pt-8 border-t border-white/10">
      <div class="flex flex-col md:flex-row items-center justify-between gap-6">
        {/* Copyright */}
        <div class="flex items-center gap-3">
          <div class="w-8 h-8 rounded-lg flex items-center justify-center" style="background: rgba(114,205,0,0.15)">
            <span class="text-[#72CD00] text-xs font-bold">©</span>
          </div>
          <p class="text-white/60 text-sm font-['Inter',sans-serif]">
            2026 Groupe CERIN — Tous droits réservés
          </p>
        </div>

        {/* Legal links */}
        <div class="flex items-center gap-2 md:gap-4">
          {[
            { label: "Mentions légales", href: "/mentions-legales" },
            { label: "Politique de confidentialité", href: "/confidentialite" },
            { label: "Cookies", href: "/cookies" }
          ].map((item, index) => (
            <>
              {index > 0 && (
                <span class="hidden md:inline w-1 h-1 rounded-full bg-[#72CD00]/40"></span>
              )}
              <a 
                href={item.href}
                class="text-sm text-white/50 hover:text-[#FEFF01] transition-all duration-200 hover:underline underline-offset-4 font-['Inter',sans-serif]"
              >
                {item.label}
              </a>
            </>
          ))}
        </div>
      </div>

      {/* Additional info */}
      <div class="mt-6 pt-6 border-t border-white/5 text-center">
        <p class="text-white/30 text-xs font-['Inter',sans-serif]">
          Conçu avec passion pour l'excellence éducative en Côte d'Ivoire
        </p>
      </div>
    </div>
  </div>
</footer>
