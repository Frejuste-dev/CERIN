---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import PageHero from "../components/shared/PageHero.astro";
import { Image as ImageIcon } from "lucide-react";
import { getGallery } from "../lib/content";

const G = "#7AC943";
const BG = "#F5F6F8";

const { data: galleryItems } = await getGallery({
  sort: ['created_at:desc'],
  populate: '*',
});
---

<Layout title="Galerie – Groupe CERIN">
  <Header />
  <main class="pt-20">
    <PageHero
      title="Galerie"
      subtitle="Découvrez la vie au sein du Groupe CERIN à travers nos photos : campus, événements, clubs et réussites."
      image="https://images.unsplash.com/photo-1523050854058-8df90110c9f1?auto=format&fit=crop&w=1200&q=80"
      breadcrumbs={[{ label: "Galerie" }]}
      accent={G}
    />

    <section class="py-20" style={{ background: BG }}>
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        {(galleryItems?.length || 0) > 0 ? (
          <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
            {galleryItems!.map((photo: any) => (
              <div class="group relative rounded-2xl overflow-hidden bg-white border border-gray-100 hover:shadow-xl transition-shadow" style={{ boxShadow: "0 4px 16px rgba(0,0,0,0.05)" }}>
                <div class="relative h-56 overflow-hidden">
                  <img src={photo.image?.url || 'https://images.unsplash.com/photo-1523050854058-8df90110c9f1?auto=format&fit=crop&w=800&q=80'} alt={photo.title} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" onerror="this.src='https://images.unsplash.com/photo-1523050854058-8df90110c9f1?auto=format&fit=crop&w=800&q=80'; this.onerror=null;" />
                  <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
                  <div class="absolute bottom-0 left-0 right-0 p-4 translate-y-4 group-hover:translate-y-0 opacity-0 group-hover:opacity-100 transition-all duration-300">
                    <p class="text-white text-sm font-semibold" style="font-family: 'Poppins', sans-serif">{photo.title}</p>
                    <span class="text-white text-xs opacity-80">{photo.category} • {photo.year}</span>
                  </div>
                </div>
              </div>
            ))}
          </div>
        ) : (
          <div class="text-center py-20">
            <p class="text-gray-400 text-lg">Aucune photo disponible pour le moment.</p>
            <p class="text-gray-400 text-sm mt-2">Revenez bientôt découvrir notre galerie.</p>
          </div>
        )}
      </div>
    </section>

    <section class="py-20 bg-white">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <div class="w-16 h-16 rounded-2xl flex items-center justify-center mx-auto mb-6" style={{ background: "#F0FAF0" }}>
          <ImageIcon size={32} style={{ color: G }} />
        </div>
        <h2 class="text-2xl md:text-3xl font-extrabold text-gray-900 mb-4" style="font-family: 'Poppins', sans-serif">
          Vivez l'expérience CERIN
        </h2>
        <p class="text-gray-600 mb-8" style="font-family: 'Inter', sans-serif">
          La galerie est mise à jour régulièrement. Suivez-nous sur les réseaux sociaux pour ne manquer aucun moment fort de la vie du campus.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href="/contact" class="inline-flex items-center gap-2 px-8 py-4 rounded-xl font-bold text-white transition-all hover:shadow-lg hover:-translate-y-0.5" style={{ background: G, fontFamily: "'Poppins', sans-serif" }}>
            Nous contacter
          </a>
          <a href="/actualites" class="inline-flex items-center gap-2 px-8 py-4 rounded-xl font-bold border-2 transition-all hover:bg-gray-50" style={{ border: "2px solid #E5E7EB", color: "#374151", fontFamily: "'Poppins', sans-serif" }}>
            Voir les actualités
          </a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
