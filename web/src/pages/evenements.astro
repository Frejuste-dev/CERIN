---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import PageHero from "../components/shared/PageHero.astro";
import { Calendar, MapPin, Clock, Users } from "lucide-react";
import { getUpcomingEvents } from "../lib/content";

const G = "#7AC943";
const BG = "#F5F6F8";

const { data: cmsEvents } = await getUpcomingEvents();
---

<Layout title="Événements – Groupe CERIN">
  <Header />
  <main class="pt-20">
    <PageHero
      title="Événements"
      subtitle="Toute l'actualité du Groupe CERIN : portes ouvertes, conférences, sport et cérémonies."
      image="https://images.unsplash.com/photo-1540575467063-178a50c2df87?auto=format&fit=crop&w=1200&q=80"
      breadcrumbs={[{ label: "Événements" }]}
      accent={G}
    />

    <section class="py-20" style={{ background: BG }}>
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        {(cmsEvents?.length || 0) > 0 ? (
          <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {cmsEvents!.map((ev: any) => (
              <a href={`/evenements/${ev.slug}`} class="block rounded-2xl overflow-hidden border border-gray-100 hover:shadow-xl transition-all hover:-translate-y-1 bg-white" style={{ boxShadow: "0 4px 16px rgba(0,0,0,0.05)" }}>
                <div class="relative h-48 overflow-hidden">
                  <img src={ev.image?.url || '/images/placeholder.svg'} alt={ev.title} class="w-full h-full object-cover" onerror="this.src='/images/placeholder.svg'; this.onerror=null;" />
                  <span class="absolute top-3 left-3 px-3 py-1 rounded-full text-xs font-semibold text-white" style={{ background: G }}>Événement</span>
                </div>
                <div class="p-6">
                  <h3 class="text-lg font-bold text-gray-900 mb-3" style="font-family: 'Poppins', sans-serif">{ev.title}</h3>
                  <div class="space-y-2 text-sm text-gray-600" style={{ fontFamily: "'Inter', sans-serif" }}>
                    <div class="flex items-center gap-2">
                      <Calendar size={15} style={{ color: G }} />
                      <span>{new Date(ev.start_date).toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' })}</span>
                    </div>
                    {ev.start_date && (
                      <div class="flex items-center gap-2">
                        <Clock size={15} style={{ color: G }} />
                        <span>{new Date(ev.start_date).toLocaleTimeString('fr-FR', { hour: '2-digit', minute: '2-digit' })}</span>
                      </div>
                    )}
                    {ev.location && (
                      <div class="flex items-center gap-2">
                        <MapPin size={15} style={{ color: G }} />
                        <span>{ev.location}</span>
                      </div>
                    )}
                  </div>
                </div>
              </a>
            ))}
          </div>
        ) : (
          <div class="text-center py-20">
            <p class="text-gray-400 text-lg">Aucun événement à venir pour le moment.</p>
            <p class="text-gray-400 text-sm mt-2">Revenez bientôt découvrir nos prochains événements.</p>
          </div>
        )}
      </div>
    </section>

    <section class="py-20 bg-white">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-2xl md:text-3xl font-extrabold text-gray-900 mb-4" style="font-family: 'Poppins', sans-serif">
          Participez à la vie du campus
        </h2>
        <p class="text-gray-600 mb-8" style="font-family: 'Inter', sans-serif">
          Les événements du CERIN sont ouverts à tous : élèves, étudiants, parents et partenaires. Restez informés et rejoignez-nous !
        </p>
        <a href="/contact" class="inline-flex items-center gap-2 px-8 py-4 rounded-xl font-bold text-white transition-all hover:shadow-lg hover:-translate-y-0.5" style={{ background: G, fontFamily: "'Poppins', sans-serif" }}>
          <Users size={18} />
          S'inscrire à la newsletter
        </a>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
