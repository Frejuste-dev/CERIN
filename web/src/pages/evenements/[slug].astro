---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import PageHero from "../../components/shared/PageHero.astro";
import { ArrowLeft, Calendar, MapPin, Clock, Users } from "lucide-react";
import { getEvents, getEventBySlug } from "../../lib/content";
import type { Event } from "../../lib/api/types";

const G = "#7AC943";

// ─── Static Paths (SSG) ───────────────────────────────────────────────────────
export async function getStaticPaths() {
  const { data: allEvents } = await getEvents({
    populate: '*',
    pageSize: 100,
  });

  return allEvents.map((event: Event) => ({
    params: { slug: event.slug },
    props: { event },
  }));
}

// ─── Props ────────────────────────────────────────────────────────────────────
const { slug } = Astro.params;
let { event } = Astro.props as { event: Event };

// Fallback fetch (SSR mode or preview)
if (!event) {
  const result = await getEventBySlug(slug as string);
  if (!result) {
    return Astro.redirect('/404');
  }
  event = result.data;
}

// ─── Dates ────────────────────────────────────────────────────────────────────
const startDate = new Date(event.start_date);
const endDate = event.end_date ? new Date(event.end_date) : null;

const formattedStart = startDate.toLocaleDateString('fr-FR', {
  weekday: 'long',
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const formattedStartTime = startDate.toLocaleTimeString('fr-FR', {
  hour: '2-digit',
  minute: '2-digit',
});
const formattedEnd = endDate?.toLocaleDateString('fr-FR', {
  weekday: 'long',
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const formattedEndTime = endDate?.toLocaleTimeString('fr-FR', {
  hour: '2-digit',
  minute: '2-digit',
});

const isUpcoming = startDate.getTime() >= Date.now();
const isSameDay = endDate
  ? startDate.toDateString() === endDate.toDateString()
  : true;

// ─── SEO ──────────────────────────────────────────────────────────────────────
const pageTitle = event.seo_title || `${event.title} – Groupe CERIN`;
const pageDesc =
  event.seo_description ||
  `${event.title} – ${formattedStart}${event.location ? ` à ${event.location}` : ''}. Événement du Groupe CERIN.`;
const ogImageUrl = event.og_image?.url || event.image?.url;
---

<Layout
  title={pageTitle}
  description={pageDesc}
  canonical={event.canonical_url}
  ogImage={ogImageUrl}
  ogType="article"
>
  <Header />

  <main class="pt-20">
    <PageHero
      title={event.title}
      subtitle={pageDesc}
      image={event.image?.url || 'https://images.unsplash.com/photo-1540575467063-178a50c2df87?auto=format&fit=crop&w=1200&q=80'}
      breadcrumbs={[
        { label: 'Événements', href: '/evenements' },
        { label: event.title },
      ]}
      accent={G}
    />

    <!-- Sticky nav bar -->
    <div class="bg-white border-b border-gray-100 sticky top-20 z-10">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-3 flex items-center justify-between flex-wrap gap-3">
        <a
          href="/evenements"
          class="inline-flex items-center gap-2 text-sm font-semibold hover:underline"
          style={{ color: G, fontFamily: "'Inter', sans-serif" }}
        >
          <ArrowLeft size={16} /> Tous les événements
        </a>
        <span
          class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-bold"
          style={isUpcoming
            ? { background: G + '18', color: G }
            : { background: '#F3F4F6', color: '#6B7280' }}
        >
          {isUpcoming ? '📅 À venir' : '✓ Passé'}
        </span>
      </div>
    </div>

    <!-- Event detail layout -->
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
      <div class="grid lg:grid-cols-3 gap-12">

        <!-- Main content (left / 2 cols) -->
        <div class="lg:col-span-2">
          <!-- Cover image -->
          {event.image?.url && (
            <div class="w-full aspect-video rounded-3xl overflow-hidden mb-10 shadow-lg">
              <img
                src={event.image.url}
                alt={event.title}
                class="w-full h-full object-cover"
                onerror="this.src='/images/placeholder.svg'; this.onerror=null;"
              />
            </div>
          )}

          <!-- H1 for SEO -->
          <h1 class="text-3xl md:text-4xl font-extrabold text-gray-900 mb-6 leading-tight" style="font-family:'Poppins',sans-serif">
            {event.title}
          </h1>

          <!-- Rich text description -->
          <div
            class="event-body prose prose-lg max-w-none"
            set:html={event.description}
            style="font-family:'Inter',sans-serif"
          />

          <!-- Back button -->
          <div class="mt-12 pt-8 border-t border-gray-200">
            <a
              href="/evenements"
              class="inline-flex items-center gap-2 px-6 py-3 rounded-xl font-bold text-sm text-white transition-all hover:shadow-lg hover:-translate-y-0.5"
              style={{ background: G, fontFamily: "'Poppins', sans-serif" }}
            >
              <ArrowLeft size={16} /> Retour aux événements
            </a>
          </div>
        </div>

        <!-- Sidebar (right / 1 col) -->
        <aside>
          <div
            class="rounded-3xl p-7 sticky top-36"
            style={{ background: '#F9FAFB', border: '1.5px solid #E5E7EB' }}
          >
            <h2 class="text-lg font-bold text-gray-900 mb-6" style="font-family:'Poppins',sans-serif">
              Informations pratiques
            </h2>

            <div class="space-y-5">
              <!-- Date start -->
              <div class="flex items-start gap-3">
                <div class="w-9 h-9 rounded-xl flex items-center justify-center flex-shrink-0" style={{ background: G + '18' }}>
                  <Calendar size={18} style={{ color: G }} />
                </div>
                <div>
                  <p class="text-xs font-semibold text-gray-500 mb-0.5" style="font-family:'Inter',sans-serif">
                    {endDate && !isSameDay ? 'Date de début' : 'Date'}
                  </p>
                  <p class="text-sm font-semibold text-gray-900 capitalize" style="font-family:'Inter',sans-serif">
                    {formattedStart}
                  </p>
                </div>
              </div>

              <!-- Date end (if different day) -->
              {endDate && !isSameDay && (
                <div class="flex items-start gap-3">
                  <div class="w-9 h-9 rounded-xl flex items-center justify-center flex-shrink-0" style={{ background: G + '18' }}>
                    <Calendar size={18} style={{ color: G }} />
                  </div>
                  <div>
                    <p class="text-xs font-semibold text-gray-500 mb-0.5" style="font-family:'Inter',sans-serif">Date de fin</p>
                    <p class="text-sm font-semibold text-gray-900 capitalize" style="font-family:'Inter',sans-serif">
                      {formattedEnd}
                    </p>
                  </div>
                </div>
              )}

              <!-- Time -->
              <div class="flex items-start gap-3">
                <div class="w-9 h-9 rounded-xl flex items-center justify-center flex-shrink-0" style={{ background: G + '18' }}>
                  <Clock size={18} style={{ color: G }} />
                </div>
                <div>
                  <p class="text-xs font-semibold text-gray-500 mb-0.5" style="font-family:'Inter',sans-serif">Heure</p>
                  <p class="text-sm font-semibold text-gray-900" style="font-family:'Inter',sans-serif">
                    {formattedStartTime}
                    {formattedEndTime && isSameDay && ` – ${formattedEndTime}`}
                  </p>
                </div>
              </div>

              <!-- Location -->
              {event.location && (
                <div class="flex items-start gap-3">
                  <div class="w-9 h-9 rounded-xl flex items-center justify-center flex-shrink-0" style={{ background: G + '18' }}>
                    <MapPin size={18} style={{ color: G }} />
                  </div>
                  <div>
                    <p class="text-xs font-semibold text-gray-500 mb-0.5" style="font-family:'Inter',sans-serif">Lieu</p>
                    <p class="text-sm font-semibold text-gray-900" style="font-family:'Inter',sans-serif">
                      {event.location}
                    </p>
                  </div>
                </div>
              )}
            </div>

            <!-- CTA -->
            {isUpcoming && (
              <a
                href="/contact"
                class="mt-8 flex items-center justify-center gap-2 w-full px-6 py-4 rounded-2xl font-bold text-sm text-white transition-all hover:shadow-lg hover:-translate-y-0.5"
                style={{ background: G, fontFamily: "'Poppins', sans-serif" }}
              >
                <Users size={16} /> S'inscrire à l'événement
              </a>
            )}
          </div>
        </aside>
      </div>
    </div>
  </main>

  <Footer />
</Layout>

<style>
  /* Event body rich text */
  .event-body :global(h2) {
    font-family: 'Poppins', sans-serif;
    font-size: 1.4rem;
    font-weight: 700;
    color: #111827;
    margin: 1.75rem 0 0.75rem;
  }
  .event-body :global(p) {
    color: #374151;
    line-height: 1.8;
    margin-bottom: 1.25rem;
  }
  .event-body :global(ul),
  .event-body :global(ol) {
    margin: 1rem 0 1.25rem 1.5rem;
    color: #374151;
  }
  .event-body :global(li) {
    margin-bottom: 0.5rem;
    line-height: 1.7;
  }
  .event-body :global(strong) {
    color: #111827;
    font-weight: 700;
  }
  .event-body :global(a) {
    color: #7AC943;
    text-decoration: underline;
  }
  .event-body :global(blockquote) {
    border-left: 4px solid #7AC943;
    padding: 1rem 1.5rem;
    margin: 1.5rem 0;
    background: #F9FAFB;
    border-radius: 0 12px 12px 0;
    color: #374151;
    font-style: italic;
  }
</style>
