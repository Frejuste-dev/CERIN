---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { Briefcase, CheckCircle, ArrowRight } from "lucide-react";

const BG = "#F8FBF8";
const G = "#7AC943";

const offers = [
  {
    title: "Enseignant Permanent",
    description: "Nous recrutons des enseignants permanents qualifiés pour accompagner durablement nos élèves et étudiants dans leur parcours académique.",
    requirements: [
      "Diplôme requis", 
      "Expérience pédagogique", 
      "Maîtrise de la discipline"
    ],
    link: "/offres/postuler?poste=teacher_permanent"
  },
  {
    title: "Enseignant Vacataire",
    description: "Nous recherchons des enseignants vacataires pour des interventions ponctuelles dans différentes filières.",
    requirements: [
      "Expertise métier", 
      "Disponibilité flexible", 
      "Expérience terrain appréciée"
    ],
    link: "/offres/postuler?poste=teacher_temporary"
  }
];
---

<Layout>
  <Header />

  <main class="min-h-screen pt-28 pb-20" style={`background-color: ${BG}`}>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      
      {/* Hero Section */}
      <div class="text-center mb-16">
        <span class="inline-block px-4 py-1.5 rounded-full text-sm font-semibold mb-4 bg-green-100 text-green-800 tracking-wide">
          CARRIÈRES
        </span>
        <h1 class="text-4xl md:text-5xl font-extrabold text-gray-900 mb-6 font-['Poppins',sans-serif]">
          Rejoignez le Groupe CERIN
        </h1>
        <p class="text-lg md:text-xl text-gray-600 font-['Inter',sans-serif] max-w-2xl mx-auto leading-relaxed">
          Découvrez nos opportunités de recrutement
        </p>
      </div>

      {/* Offers Section */}
      <div class="grid md:grid-cols-2 gap-8 max-w-5xl mx-auto">
        {offers.map(offer => (
          <div class="bg-white rounded-3xl p-8 sm:p-10 border border-gray-100 shadow-sm hover:shadow-2xl transition-all duration-300 flex flex-col hover:-translate-y-1">
            <div class="w-14 h-14 rounded-2xl flex items-center justify-center mb-6" style="background: #F0FAF0">
              <Briefcase size={28} style={{ color: G }} />
            </div>
            
            <h2 class="text-2xl font-bold text-gray-900 mb-4 font-['Poppins',sans-serif]">
              {offer.title}
            </h2>
            
            <p class="text-gray-600 mb-8 leading-relaxed font-['Inter',sans-serif] flex-grow text-lg">
              {offer.description}
            </p>
            
            <div class="mb-10 space-y-4 border-t border-gray-50 pt-8 mt-auto">
              <h3 class="text-sm font-bold text-gray-900 uppercase tracking-wider mb-5">
                Profil recherché
              </h3>
              {offer.requirements.map(req => (
                <div class="flex items-start gap-3">
                  <CheckCircle size={20} class="shrink-0 mt-0.5" style={{ color: G }} />
                  <span class="text-gray-700 font-medium">{req}</span>
                </div>
              ))}
            </div>
            
            <a 
              href={offer.link}
              class="inline-flex items-center justify-center w-full py-4 rounded-xl font-bold text-white transition-all hover:bg-green-700 hover:shadow-lg group"
              style="background: #7AC943"
            >
              Postuler
              <ArrowRight size={20} class="ml-2 group-hover:translate-x-1 transition-transform" />
            </a>
          </div>
        ))}
      </div>
      
    </div>
  </main>

  <Footer />
</Layout>
