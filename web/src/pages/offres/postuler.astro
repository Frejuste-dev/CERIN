---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import ApplicationForm from "../../components/application/ApplicationForm";

const G = "#7AC943";
const BG = "#F8FBF8";
---

<Layout>
  <Header />
  
  <main class="min-h-screen pt-24 pb-20" style={`background-color: ${BG}`}>
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      
      {/* Header Section */}
      <div class="text-center mb-12">
        <span class="inline-block px-4 py-1.5 rounded-full text-sm font-semibold mb-4 bg-green-100 text-green-800">
          Recrutement
        </span>
        <h1 class="text-4xl md:text-5xl font-extrabold text-gray-900 mb-4 font-['Poppins',sans-serif]">
          Rejoignez le Groupe CERIN
        </h1>
        <p class="text-lg text-gray-600 font-['Inter',sans-serif] max-w-2xl mx-auto">
          Nous sommes constamment à la recherche de talents passionnés pour rejoindre notre équipe pédagogique et administrative.
        </p>
      </div>

      {/* Form Section */}
      <ApplicationForm client:load />
      
    </div>
  </main>

  <Footer />
</Layout>
