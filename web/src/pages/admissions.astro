---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import PageHero from "../components/shared/PageHero.astro";
import { AdmissionForm } from "../components/AdmissionForm";
import { AdmissionsFAQ } from "../components/AdmissionsFAQ";
import { CheckCircle, GraduationCap, Wrench, Building2, Award, Globe, Phone, Mail, MessageCircle, MapPin } from "lucide-react";

const Y = "#FEFF01";
const BG = "#F5F6F8";
const G = "#72CD00";
const DARK = "#0B0B0B";

const heroImages = [
  'https://images.unsplash.com/photo-1523050854058-8df90110c9f1?auto=format&fit=crop&w=1200&q=80',
  'https://images.unsplash.com/photo-1427504494785-3a9ca7044f45?auto=format&fit=crop&w=1200&q=80',
  'https://images.unsplash.com/photo-1522202176988-66273c2fd55f?auto=format&fit=crop&w=1200&q=80'
];

const advantages = [
  { icon: GraduationCap, title: "Formateurs experts", desc: "Des professionnels expérimentés passionnés par la transmission du savoir." },
  { icon: Wrench, title: "Méthodes innovantes", desc: "Un apprentissage de pointe avec des outils modernes et des projets concrets." },
  { icon: Building2, title: "Stages en entreprise", desc: "Une immersion professionnelle et un suivi personnalisé vers l'insertion." },
  { icon: Award, title: "Diplômes reconnus", desc: "Des qualifications reconnues par l'État qui ouvrent de nouvelles opportunités." },
  { icon: Globe, title: "Bourse en Chine", desc: "Possibilité d'obtenir une bourse d'étude après le BAC ou le BT." },
];

const admissionSteps = [
  { step: "01", title: "Remplir le formulaire", desc: "Complétez vos informations personnelles et votre projet de formation en ligne.", icon: GraduationCap },
  { step: "02", title: "Soumettre les documents", desc: "Téléchargez vos bulletins, diplômes et justificatifs d'identité.", icon: Wrench },
  { step: "03", title: "Passer l'entretien", desc: "Un échange constructif avec notre équipe pédagogique pour valider votre projet.", icon: Building2 },
  { step: "04", title: "Confirmation d'admission", desc: "Recevez votre lettre d'acceptation et préparez votre rentrée au CERIN.", icon: Award },
];

const contactInfo = {
  address: "Yopougon Songon (Institut Pasteur), Abidjan, Côte d'Ivoire",
  phones: ["01 025 555 50", "05 454 579 19", "07 790 202 07"],
  fixed: "27 235 643 36",
  email: "infos@ceringroup.com",
  whatsapp: "https://wa.me/2250102555550",
};
---

<Layout title="Admissions – Groupe CERIN">
  <Header />

  <main class="pt-20">
    <PageHero
      title="Admissions"
      subtitle="Rejoignez le Groupe CERIN et construisez votre avenir académique. Déposez votre dossier en ligne en 4 étapes simples."
      images={heroImages}
      useSlider={true}
      breadcrumbs={[{ label: "Admissions" }]}
      accent={Y}
    />

    <!-- Contact + Form Section -->
    <section class="py-20 bg-light-gray">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid lg:grid-cols-3 gap-8">

          <!-- Left Column: Form (2/3) -->
          <div class="lg:col-span-2">
            <div class="bg-white rounded-3xl p-6 md:p-10 shadow-card">
              <AdmissionForm />
            </div>
          </div>

          <!-- Right Column: Sticky Sidebar (1/3) -->
          <div class="lg:col-span-1 space-y-6">
            <div class="lg:sticky lg:top-24 space-y-6">
              <!-- Contact Card -->
              <div class="bg-white rounded-3xl p-6 md:p-8 border border-gray-100 shadow-card">
                <h3 class="text-xl font-extrabold text-gray-900 mb-5 font-poppins">
                  Contact & Assistance
                </h3>
                <div class="space-y-4">
                  <div class="flex items-start gap-3">
                    <div class="w-10 h-10 rounded-xl flex items-center justify-center shrink-0 bg-light-green">
                      <MapPin size={18} class="text-primary-green" />
                    </div>
                    <p class="text-sm text-gray-600 font-inter">{contactInfo.address}</p>
                  </div>
                  <div class="flex items-start gap-3">
                    <div class="w-10 h-10 rounded-xl flex items-center justify-center shrink-0 bg-light-green">
                      <Phone size={18} class="text-primary-green" />
                    </div>
                    <div class="text-sm text-gray-600 font-inter">
                      <p class="font-semibold text-gray-900">(+225) {contactInfo.phones[0]}</p>
                      <p>(+225) {contactInfo.phones[1]}</p>
                      <p>(+225) {contactInfo.phones[2]}</p>
                      <p class="text-xs text-gray-400 mt-1">Fixe : (+225) {contactInfo.fixed}</p>
                    </div>
                  </div>
                  <div class="flex items-start gap-3">
                    <div class="w-10 h-10 rounded-xl flex items-center justify-center shrink-0 bg-light-green">
                      <Mail size={18} class="text-primary-green" />
                    </div>
                    <a href={`mailto:${contactInfo.email}`} class="text-sm font-medium transition-colors text-primary-green font-inter">
                      {contactInfo.email}
                    </a>
                  </div>
                  <a
                    href={contactInfo.whatsapp}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="flex items-center justify-center gap-2 w-full py-3.5 rounded-xl font-bold text-white transition-all hover:shadow-lg hover:-translate-y-0.5 font-poppins"
                    style={{ background: "#25D366" }}
                  >
                    <MessageCircle size={18} />
                    Contactez-nous sur WhatsApp
                  </a>
                </div>
              </div>

              <!-- Quick Requirements -->
              <div class="bg-white rounded-3xl p-6 md:p-8 border border-gray-100 shadow-card">
                <h3 class="text-lg font-extrabold text-gray-900 mb-4 font-poppins">
                  Documents à préparer
                </h3>
                <ul class="space-y-3">
                  {["Bulletins scolaires des 2 dernières années", "Copie de l'acte de naissance", "Copie de la CNI ou passeport", "Certificat de résidence", "Photos d'identité (4 copies)", "Diplôme précédent (si applicable)"].map((d) => (
                    <li class="flex items-start gap-3 text-sm text-gray-700 font-inter">
                      <CheckCircle size={16} class="shrink-0 mt-0.5 text-primary-green" />
                      {d}
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Why CERIN Section -->
    <section class="py-20 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-14">
          <span class="inline-block px-4 py-1.5 rounded-full text-xs font-semibold mb-4 badge-green">
            Nos atouts
          </span>
          <h2 class="text-3xl md:text-4xl font-extrabold text-gray-900 mb-4 font-poppins">
            Pourquoi choisir le Groupe CERIN ?
          </h2>
          <p class="text-gray-600 max-w-2xl mx-auto font-inter">
            Une institution d'excellence qui place la réussite de chaque étudiant au cœur de sa mission.
          </p>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {advantages.map((adv) => {
            const Icon = adv.icon;
            return (
              <div class="group p-6 md:p-8 rounded-2xl border border-gray-100 hover:shadow-xl transition-all duration-300 hover:-translate-y-1 bg-white shadow-card">
                <div class="w-14 h-14 rounded-2xl flex items-center justify-center mb-5 bg-light-green">
                  <Icon size={28} class="text-primary-green" />
                </div>
                <h3 class="text-lg font-bold text-gray-900 mb-2 font-poppins">{adv.title}</h3>
                <p class="text-sm text-gray-600 leading-relaxed font-inter">{adv.desc}</p>
              </div>
            );
          })}
        </div>
      </div>
    </section>

    <!-- Process Section -->
    <section class="py-20 bg-light-gray">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-14">
          <span class="inline-block px-4 py-1.5 rounded-full text-xs font-semibold mb-4 badge-green">
            Parcours
          </span>
          <h2 class="text-3xl md:text-4xl font-extrabold text-gray-900 mb-4 font-poppins">
            Processus d'admission
          </h2>
          <p class="text-gray-600 max-w-2xl mx-auto font-inter">
            De votre première candidature jusqu'à la confirmation, notre équipe vous accompagne à chaque étape.
          </p>
        </div>

        <!-- Enhanced Timeline -->
        <div class="relative">
          <!-- Timeline Line (Desktop) -->
          <div class="hidden lg:block absolute top-1/2 left-0 right-0 h-1 bg-gradient-to-r from-transparent via-[#72CD00] to-transparent transform -translate-y-1/2"></div>
          
          <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-8">
            {admissionSteps.map((s, index) => {
              const Icon = s.icon;
              return (
                <div class="relative group">
                  {/* Timeline Dot (Desktop) */}
                  <div class="hidden lg:block absolute top-1/2 left-1/2 w-5 h-5 bg-[#72CD00] rounded-full border-4 border-white shadow-lg transform -translate-x-1/2 -translate-y-1/2 z-10 group-hover:scale-125 transition-transform duration-300"></div>
                  
                  <div class="relative bg-white p-6 md:p-8 rounded-2xl border border-gray-100 text-center hover:shadow-xl transition-all duration-300 hover:-translate-y-2 shadow-card">
                    {/* Step Number Badge */}
                    <div class="absolute -top-4 left-1/2 transform -translate-x-1/2 w-12 h-12 rounded-full flex items-center justify-center bg-[#72CD00] text-white font-black text-lg shadow-lg group-hover:scale-110 transition-transform duration-300 font-poppins">
                      {s.step}
                    </div>
                    
                    {/* Icon */}
                    <div class="w-16 h-16 rounded-2xl flex items-center justify-center mx-auto mb-5 bg-[#E8F5D0] group-hover:bg-[#72CD00] transition-colors duration-300">
                      <Icon size={32} class="text-[#72CD00] group-hover:text-white transition-colors duration-300" />
                    </div>
                    
                    <h3 class="text-lg font-bold text-gray-900 mb-2 font-poppins">{s.title}</h3>
                    <p class="text-sm text-gray-600 leading-relaxed font-inter">{s.desc}</p>
                    
                    {/* Connector Line (Mobile) */}
                    {index < admissionSteps.length - 1 && (
                      <div class="lg:hidden absolute top-1/2 -right-4 w-8 h-0.5 bg-[#72CD00]/30 transform -translate-y-1/2"></div>
                    )}
                  </div>
                </div>
              );
            })}
          </div>
        </div>
      </div>
    </section>

    <AdmissionsFAQ client:load />
  </main>

  <Footer />
</Layout>
