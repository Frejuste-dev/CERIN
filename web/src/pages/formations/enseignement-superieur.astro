---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import PageHero from "../../components/shared/PageHero.astro";
import { TrustStatsSection } from "../../components/TrustStatsSection";
import { TestimonialCarousel } from "../../components/TestimonialCarousel";
import FinalCtaBanner from "../../components/FinalCtaBanner.astro";
import { Monitor, BarChart2, Wifi, TrendingUp, HardHat, Globe } from "lucide-react";
import { getPrograms } from "../../lib/content";
import type { Program } from "../../lib/api/types";

const G = "#7AC943";
const Y = "#F4D000";
const BG = "#F5F6F8";

const { data: programs } = await getPrograms({
  filters: { category: { $eq: "SUPERIEUR" } },
  sort: ['level:asc', 'title:asc'],
  populate: '*',
});

const programsByLevel: Record<string, Program[]> = {};
programs?.forEach((p: Program) => {
  const level = p.level || "Autre";
  if (!programsByLevel[level]) programsByLevel[level] = [];
  programsByLevel[level].push(p);
});

const tabs = Object.keys(programsByLevel);
const labels: Record<string, string> = {
  "Bac+2": "BTS — Bac+2",
  "Bac+3": "Licence / Bachelor — Bac+3",
  "Bac+5": "Master — Bac+5",
};
const accentColors: Record<string, string> = {
  "Bac+2": G,
  "Bac+3": Y,
  "Bac+5": "#0B0B0B",
};

const iconMap: Record<string, any> = {
  "BTS INFO": Monitor,
  "BTS COMPTA": BarChart2,
  "BTS TELECOM": Wifi,
  "BTS MARKETING": TrendingUp,
  "BTS GC": HardHat,
  "BACH INFO": Monitor,
  "BACH GESTION": BarChart2,
  "BACH COM": Globe,
  "BACH INDUS": HardHat,
  "MST PROJET": TrendingUp,
  "MST DSI": Monitor,
  "MST FINANCE": BarChart2,
};

function getIcon(program: Program) {
  return iconMap[program.slug] || Monitor;
}
---

<Layout>
  <Header />

  <main class="pt-20">
    <PageHero
      title="Enseignement Supérieur"
      subtitle="Construisez votre avenir professionnel avec des diplômes reconnus — BTS, Licence, Master."
      image="https://images.unsplash.com/photo-1523050854058-8df90110c9f1?auto=format&fit=crop&w=1200&q=80"
      breadcrumbs={[{ label: "Enseignement Supérieur" }]}
      accent={G}
    >
      <div class="flex flex-wrap gap-3 mt-8">
        {(tabs.length > 0 ? tabs : ["BTS", "Licence", "Master"]).map((l) => (
          <span class="px-5 py-2 rounded-full text-sm font-semibold" style={{ background: accentColors[l] || G, color: (accentColors[l] === Y || accentColors[l] === "#0B0B0B") ? "#0B0B0B" : "white" }}>{labels[l] || l}</span>
        ))}
      </div>
    </PageHero>

    <!-- 1. Trust Stats Section (React Island) -->
    <TrustStatsSection client:load />

    <!-- 2. Program Selector -->
    <section class="py-24 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <span class="inline-block px-4 py-1.5 rounded-full text-xs font-semibold mb-4" style={{ background: "#F0FAF0", color: G }}>Programmes</span>
          <h2 class="text-gray-900 mb-3 font-extrabold text-3xl font-['Poppins',sans-serif]">
            Choisissez votre niveau
          </h2>
        </div>

        <!-- Tab selector -->
        {tabs.length > 0 && (
        <div class="flex justify-center mb-10">
          <div class="inline-flex rounded-2xl p-1.5" style={{ background: BG }}>
            {tabs.map((t) => (
              <button
                class="tab-btn px-6 py-3 rounded-xl text-sm font-semibold transition-all duration-200"
                data-tab={t}
                style={t === tabs[0] ? { background: accentColors[t] || G, color: "white", boxShadow: "0 4px 12px rgba(0,0,0,0.12)" } : { color: "#6B7280" }}
              >
                {labels[t] || t}
              </button>
            ))}
          </div>
        </div>
        )}

        <!-- Cards grids -->
        {tabs.map((t) => {
          const list = programsByLevel[t] || [];
          const acc = accentColors[t] || G;
          return (
            <div id={`grid-${t}`} class={`grid sm:grid-cols-2 lg:grid-cols-3 gap-5 ${t === tabs[0] ? "" : "hidden"}`}>
              {list.map((p) => {
                const Icon = getIcon(p);
                const code = p.slug.split('-').map(w => w[0]?.toUpperCase()).join('').substring(0, 6).toUpperCase();
                return (
                  <a
                    href={`/formations/enseignement-superieur`}
                    class="bg-white rounded-2xl p-6 border-2 border-transparent hover:shadow-xl transition-all duration-300 hover:-translate-y-1 cursor-pointer group card-item"
                    data-accent={acc}
                    style={{ boxShadow: "0 4px 20px rgba(0,0,0,0.06)" }}
                  >
                    <div class="flex items-start justify-between mb-4">
                      <div class="w-12 h-12 rounded-2xl flex items-center justify-center" style={{ background: acc === Y ? "#FFF8CC" : "#F0FAF0" }}>
                        <Icon size={22} style={{ color: acc === "#0B0B0B" ? G : acc }} />
                      </div>
                      <span class="text-xs font-bold px-2.5 py-1 rounded-full text-white" style={{ background: acc, color: acc === Y ? "#0B0B0B" : "white" }}>
                        {code}
                      </span>
                    </div>
                    <h3 class="font-bold text-gray-800 mb-2 text-lg font-['Poppins',sans-serif]">{p.title}</h3>
                    <p class="text-xs text-gray-500 leading-relaxed mb-4 font-['Inter',sans-serif]">{p.description?.substring(0, 120)}...</p>
                    <div class="flex items-center justify-between pt-3 border-t border-gray-100 text-xs text-gray-400">
                      <span>⏱ {p.duration}</span>
                      <span>{p.tuition || 'Nous contacter'}</span>
                    </div>
                  </a>
                );
              })}
            </div>
          );
        })}
      </div>
    </section>

    <!-- 3. Social Proof (React Island) -->
    <TestimonialCarousel client:load />

    <!-- 4. Final Conversion (Astro Component) -->
    <FinalCtaBanner />
  </main>

  <Footer />
</Layout>

{tabs.length > 0 ? `
<script>
  const tabs = ${JSON.stringify(tabs)};
  const accentColors = ${JSON.stringify(accentColors)};

  const buttons = document.querySelectorAll(".tab-btn");
  const grids = tabs.map(t => document.getElementById(\`grid-\${t}\`));

  buttons.forEach(btn => {
    btn.addEventListener("click", () => {
      const selectedTab = btn.getAttribute("data-tab");

      buttons.forEach(b => {
        const t = b.getAttribute("data-tab");
        if (t === selectedTab) {
          b.style.background = accentColors[t];
          b.style.color = t === "Licence" ? "#0B0B0B" : "white";
          b.style.boxShadow = "0 4px 12px rgba(0,0,0,0.12)";
        } else {
          b.style.background = "transparent";
          b.style.color = "#6B7280";
          b.style.boxShadow = "none";
        }
      });

      grids.forEach(g => {
        if (g?.id === \`grid-\${selectedTab}\`) {
          g.classList.remove("hidden");
        } else {
          g?.classList.add("hidden");
        }
      });
    });
  });

  const cards = document.querySelectorAll(".card-item");
  cards.forEach(card => {
    const accent = card.getAttribute("data-accent");
    card.addEventListener("mouseenter", () => {
      if (accent) card.style.borderColor = accent;
    });
    card.addEventListener("mouseleave", () => {
      card.style.borderColor = "transparent";
    });
  });
</script>
` : ''}
