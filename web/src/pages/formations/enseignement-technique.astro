---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import PageHero from "../../components/shared/PageHero.astro";
import { TrustStatsSection } from "../../components/TrustStatsSection";
import { TestimonialCarousel } from "../../components/TestimonialCarousel";
import FinalCtaBanner from "../../components/FinalCtaBanner.astro";
import { ArrowRight, Zap, Calculator, HardHat, FileText, Wrench, HeartPulse, TrendingUp, Briefcase } from "lucide-react";
import { getPrograms } from "../../lib/content";
import type { Program } from "../../lib/api/types";

const G = "#7AC943";
const Y = "#F4D000";
const BG = "#F5F6F8";

const heroImages = [
  'https://images.unsplash.com/photo-1581091226825-a6a2a5aee158?auto=format&fit=crop&w=1200&q=80',
  'https://images.unsplash.com/photo-1565008447742-97f6f38c985c?auto=format&fit=crop&w=1200&q=80',
  'https://images.unsplash.com/photo-1517245386807-bb43f82c33c4?auto=format&fit=crop&w=1200&q=80'
];

const { data: programs } = await getPrograms({
  filters: { category: { $eq: "TECHNIQUE" } },
  sort: ['title:asc'],
  populate: '*',
});

const industrial = programs?.filter((p: Program) => 
  ["Électrotechnique", "Maintenance des Systèmes Informatiques", "Mécanique Automobile", "BTP – Bâtiment et Travaux Publics"].some(k => p.title.includes(k))
) || [];

const admin = programs?.filter((p: Program) => 
  ["Comptabilité et Gestion", "Secrétariat", "Action Sociale"].some(k => p.title.includes(k))
) || [];

const careers = programs?.slice(0, 6).map((p: Program) => ({
  icon: Zap,
  title: p.title,
  desc: p.description?.substring(0, 80) + '...',
  tag: "Technique",
  tagBg: G,
})) || [];
---

<Layout>
  <Header />

  <main class="pt-20">
    <PageHero
      title="Enseignement Technique & Professionnel"
      subtitle="Apprenez un métier et entrez dans la vie active avec des compétences reconnues par les professionnels."
      images={heroImages}
      useSlider={true}
      breadcrumbs={[{ label: "Technique & Professionnel" }]}
      accent={Y}
    >
      <div class="flex flex-wrap gap-3 mt-8">
        {["CAP", "BT", "Bac Technologique", "Alternance"].map((tag) => (
          <span class="px-4 py-1.5 rounded-full text-sm font-semibold" style={`background: ${Y}; color: #0B0B0B`}>{tag}</span>
        ))}
      </div>
    </PageHero>

    <!-- 1. Trust Stats (Standardized React Island) -->
    <TrustStatsSection client:load />

    <!-- 2. Specific Content - Career Grid -->
    <section class="py-20 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <span class="inline-block px-4 py-1.5 rounded-full text-xs font-semibold mb-3" style={{ background: "#FFF9CC", color: "#8A7000" }}>Métiers préparés</span>
          <h2 class="text-gray-900 mb-2 font-extrabold font-['Poppins',sans-serif]" style={{ fontSize: "clamp(1.6rem,3vw,2.3rem)" }}>
            Des formations orientées métier
          </h2>
          <p class="text-gray-500 text-sm max-w-xl mx-auto font-['Inter',sans-serif]">
            Chaque cursus est conçu avec les professionnels du secteur pour garantir une insertion rapide.
          </p>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {(careers.length > 0 ? careers : [
            { icon: Zap, title: "Électricien", desc: "Installations électriques résidentielles et industrielles", tag: "Industrie", tagBg: G },
            { icon: Calculator, title: "Comptable", desc: "Gestion financière et comptabilité des entreprises", tag: "Tertiaire", tagBg: Y },
            { icon: HardHat, title: "Génie Civil", desc: "Travaux publics, bâtiment et construction", tag: "BTP", tagBg: G },
            { icon: FileText, title: "Secrétaire", desc: "Gestion administrative et assistanat de direction", tag: "Tertiaire", tagBg: Y },
            { icon: Wrench, title: "Mécanicien", desc: "Maintenance et réparation de véhicules et machines", tag: "Industrie", tagBg: G },
            { icon: HeartPulse, title: "Médico-Social", desc: "Aide à la personne et soins de proximité", tag: "Social", tagBg: "#0B0B0B" },
          ]).map((c, i) => {
            const Icon = c.icon;
            return (
              <div key={i} class="group p-6 rounded-2xl border-2 border-transparent hover:border-yellow-300 hover:shadow-lg transition-all cursor-pointer" style={{ background: BG }}>
                <div class="flex items-start justify-between mb-4">
                  <div class="w-12 h-12 rounded-2xl flex items-center justify-center bg-white">
                    <Icon size={22} style={{ color: G }} />
                  </div>
                  <span class="px-2.5 py-1 rounded-full text-xs font-bold" style={{ background: c.tagBg, color: c.tagBg === Y ? "#0B0B0B" : "white" }}>
                    {c.tag}
                  </span>
                </div>
                <h3 class="font-bold text-gray-800 mb-1 font-['Poppins',sans-serif]">{c.title}</h3>
                <p class="text-xs text-gray-500 leading-relaxed font-['Inter',sans-serif]">{c.desc}</p>
              </div>
            );
          })}
        </div>
      </div>
    </section>

    <!-- 3. Fields Section -->
    <section class="py-20" style={{ background: BG }}>
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid lg:grid-cols-2 gap-12">
          <!-- Industrial Fields -->
          <div>
            <div class="flex items-center gap-3 mb-8">
              <div class="w-1.5 h-8 rounded-full" style={{ background: G }} />
              <div>
                <h2 class="font-black text-gray-900 text-2xl font-['Poppins',sans-serif]">Filières Industrielles</h2>
                <p class="text-gray-500 text-sm">Mécanique, électrique, génie civil</p>
              </div>
            </div>
            <div class="grid gap-4">
              {(industrial.length > 0 ? industrial : programs?.slice(0, 3) || []).map((item: Program) => (
                <div class="bg-white rounded-2xl p-5" style={{ boxShadow: "0 4px 16px rgba(0,0,0,0.06)" }}>
                  <div class="flex items-center gap-3 mb-3">
                    <div class="w-10 h-10 rounded-xl flex items-center justify-center" style={{ background: "#F0FAF0" }}>
                      <Zap size={18} style={{ color: G }} />
                    </div>
                    <span class="font-black text-xs px-2 py-1 rounded-lg text-white" style={{ background: G, fontFamily: "'Poppins',sans-serif" }}>
                      {item.slug?.substring(0, 6).toUpperCase()}
                    </span>
                  </div>
                  <p class="font-bold text-gray-800 text-sm mb-1 font-['Poppins',sans-serif]">{item.title}</p>
                  <p class="text-xs text-gray-500 font-['Inter',sans-serif]">{item.description?.substring(0, 100)}...</p>
                </div>
              ))}
            </div>
          </div>

          <!-- Tertiary Fields -->
          <div>
            <div class="flex items-center gap-3 mb-8">
              <div class="w-1.5 h-8 rounded-full" style={{ background: Y }} />
              <div>
                <h2 class="font-black text-gray-900 text-2xl font-['Poppins',sans-serif]">Filières Tertiaires</h2>
                <p class="text-gray-500 text-sm">Gestion, secrétariat, action sociale</p>
              </div>
            </div>
            <div class="grid gap-4">
              {(admin.length > 0 ? admin : programs?.slice(3, 6) || []).map((item: Program) => (
                <div class="bg-white rounded-2xl p-5" style={{ boxShadow: "0 4px 16px rgba(0,0,0,0.06)" }}>
                  <div class="flex items-center gap-3 mb-3">
                    <div class="w-10 h-10 rounded-xl flex items-center justify-center" style={{ background: "#F0FAF0" }}>
                      <Calculator size={18} style={{ color: G }} />
                    </div>
                    <span class="font-black text-xs px-2 py-1 rounded-lg text-white" style={{ background: G, fontFamily: "'Poppins',sans-serif" }}>
                      {item.slug?.substring(0, 6).toUpperCase()}
                    </span>
                  </div>
                  <p class="font-bold text-gray-800 text-sm mb-1 font-['Poppins',sans-serif]">{item.title}</p>
                  <p class="text-xs text-gray-500 font-['Inter',sans-serif]">{item.description?.substring(0, 100)}...</p>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- 4. Social Proof (Standardized React Island) -->
    <TestimonialCarousel client:load />

    <!-- 5. Final Conversion (Standardized) -->
    <FinalCtaBanner />
  </main>

  <Footer />
</Layout>
