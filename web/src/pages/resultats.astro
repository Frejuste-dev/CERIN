---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import PageHero from "../components/shared/PageHero.astro";
import { TrendingUp, Trophy, BarChart3 } from "lucide-react";

const G = "#7AC943";
const Y = "#F4D000";
const BG = "#F5F6F8";

const results = [
  { year: "2025", exam: "BAC", rate: "96%", total: "342 admis", detail: "Taux de réussite historique toutes séries confondues." },
  { year: "2025", exam: "BTS", rate: "94%", total: "128 admis", detail: "Premier taux national pour un établissement privé en Côte d'Ivoire." },
  { year: "2024", exam: "BAC", rate: "93%", total: "318 admis", detail: "Excellence maintenue avec une hausse de +2 points." },
  { year: "2024", exam: "BTS", rate: "91%", total: "115 admis", detail: "Fierté de toute la communauté éducative CERIN." },
  { year: "2023", exam: "BAC", rate: "90%", total: "295 admis", detail: "Des résultats constants qui témoignent de la qualité de nos enseignants." },
  { year: "2023", exam: "BTS", rate: "89%", total: "102 admis", detail: "Nos étudiants parmi les meilleurs du pays." },
];

const stats = [
  { label: "Taux de réussite BAC", value: "96%", icon: Trophy },
  { label: "Taux de réussite BTS", value: "94%", icon: TrendingUp },
  { label: "Étudiants diplômés", value: "250+", icon: BarChart3 },
];
---

<Layout title="Résultats – Groupe CERIN">
  <Header />
  <main class="pt-20">
    <PageHero
      title="Résultats académiques"
      subtitle="L'excellence du Groupe CERIN confirmée par les résultats aux examens nationaux."
      image="https://images.unsplash.com/photo-1523050854058-8df90110c9f1?auto=format&fit=crop&w=1200&q=80"
      breadcrumbs={[{ label: "Résultats" }]}
      accent={Y}
    />

    <section class="py-20" style={{ background: BG }}>
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid sm:grid-cols-3 gap-6 mb-16">
          {stats.map((s) => {
            const Icon = s.icon;
            return (
              <div class="bg-white p-8 rounded-2xl text-center border border-gray-100" style={{ boxShadow: "0 4px 16px rgba(0,0,0,0.05)" }}>
                <div class="w-14 h-14 rounded-2xl flex items-center justify-center mx-auto mb-4" style={{ background: "#F0FAF0" }}>
                  <Icon size={28} style={{ color: G }} />
                </div>
                <div class="text-3xl font-black text-gray-900 mb-1" style="font-family: 'Poppins', sans-serif">{s.value}</div>
                <div class="text-sm text-gray-600" style="font-family: 'Inter', sans-serif">{s.label}</div>
              </div>
            );
          })}
        </div>

        <div class="bg-white rounded-3xl overflow-hidden border border-gray-100" style={{ boxShadow: "0 8px 40px rgba(0,0,0,0.08)" }}>
          <div class="p-6 md:p-8 border-b border-gray-100">
            <h2 class="text-2xl font-extrabold text-gray-900" style="font-family: 'Poppins', sans-serif">
              Résultats par année et par examen
            </h2>
          </div>
          <div class="overflow-x-auto">
            <table class="w-full">
              <thead>
                <tr class="bg-gray-50 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider" style={{ fontFamily: "'Inter', sans-serif" }}>
                  <th class="px-6 py-4">Année</th>
                  <th class="px-6 py-4">Examen</th>
                  <th class="px-6 py-4">Taux de réussite</th>
                  <th class="px-6 py-4">Candidats admis</th>
                  <th class="px-6 py-4 hidden md:table-cell">Commentaire</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-100">
                {results.map((r) => (
                  <tr class="hover:bg-gray-50 transition-colors">
                    <td class="px-6 py-4 text-sm font-medium text-gray-900" style={{ fontFamily: "'Poppins', sans-serif" }}>{r.year}</td>
                    <td class="px-6 py-4 text-sm text-gray-700" style={{ fontFamily: "'Inter', sans-serif" }}>
                      <span class="px-2 py-1 rounded-md text-xs font-bold text-white" style={{ background: G }}>{r.exam}</span>
                    </td>
                    <td class="px-6 py-4 text-sm font-bold text-gray-900" style={{ fontFamily: "'Poppins', sans-serif" }}>{r.rate}</td>
                    <td class="px-6 py-4 text-sm text-gray-700" style={{ fontFamily: "'Inter', sans-serif" }}>{r.total}</td>
                    <td class="px-6 py-4 text-sm text-gray-500 hidden md:table-cell" style={{ fontFamily: "'Inter', sans-serif" }}>{r.detail}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </section>

    <section class="py-20 bg-white">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-2xl md:text-3xl font-extrabold text-gray-900 mb-4" style="font-family: 'Poppins', sans-serif">
          La réussite est une priorité au CERIN
        </h2>
        <p class="text-gray-600 mb-8" style="font-family: 'Inter', sans-serif">
          Nos méthodes pédagogiques innovantes, notre encadrement personnalisé et nos partenariats avec les entreprises garantissent à chaque étudiant les meilleures chances de succès.
        </p>
        <a href="/admissions" class="inline-flex items-center gap-2 px-8 py-4 rounded-xl font-bold text-white transition-all hover:shadow-lg hover:-translate-y-0.5" style={{ background: G, fontFamily: "'Poppins', sans-serif" }}>
          Pré-inscription
        </a>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
