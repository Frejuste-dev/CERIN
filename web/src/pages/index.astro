---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import EnhancedHero from "../components/EnhancedHero.astro";
import TrustStatsSection from "../components/TrustStatsSection.astro";
import TestimonialCarousel from "../components/TestimonialCarousel.astro";
import QuickNav from "../components/QuickNav.astro";
import FinalCtaBanner from "../components/FinalCtaBanner.astro";
import { getFeaturedPrograms, getFeaturedTestimonials, getNews } from "../lib/content";
import { GraduationCap, Wrench, BookOpen } from "lucide-react";

const G = "#7AC943";
const Y = "#F4D000";
const BG = "#F5F6F8";

const cerinHome = {
  hero: {
    title: "Construisez votre avenir académique avec le Groupe CERIN",
    subtitle: "Du collège jusqu'au supérieur, des programmes adaptés aux exigences du monde professionnel",
    cta: ["Inscription", "Consultez nos programmes"],
  },

  poles: [
    {
      title: "Enseignement Général",
      icon: "GraduationCap",
      items: ["Collège", "Lycée", "Économie et Gestion"],
    },
    {
      title: "Technique & Professionnel",
      icon: "Wrench",
      items: [
        "Génie Électrique",
        "Génie Civil",
        "Administration et Bureautique",
        "Vie familiale et sociale",
      ],
    },
    {
      title: "Enseignement Supérieur",
      icon: "BookOpen",
      items: ["BTS", "Licence", "Master"],
    },
  ],

  slogan: "La réussite professionnelle commence par une formation solide",

  about: {
    title: "À propos du Groupe CERIN",
    description: "Le Groupe CERIN est un établissement d'enseignement basé en Côte d'Ivoire, offrant des programmes du collège au supérieur. Nous accompagnons les étudiants dans leur parcours académique et professionnel afin de former des profils compétents et adaptés au marché du travail.",
    mission: [
      "Former des étudiants compétents et responsables",
      "Offrir une éducation de qualité",
      "Préparer l'insertion professionnelle et académique",
    ],
  },

  images: {
    graduates: "https://images.unsplash.com/photo-1523050854058-8df90110c9f1?auto=format&fit=crop&w=1200&q=80",
    students: "https://images.unsplash.com/photo-1517245386807-bb43f82c33c4?auto=format&fit=crop&w=800&q=80",
  },
};

const trustStatsData = [
  { value: 5000, suffix: "+", label: "Étudiants formés", desc: "Depuis notre création" },
  { value: 92, suffix: "%", label: "Taux de réussite", desc: "Aux examens nationaux" },
  { value: 89, suffix: "%", label: "Taux d'emploi", desc: "À 6 mois du diplôme" },
  { value: 50, suffix: "+", label: "Partenaires entreprises", desc: "Pour stages & alternance" },
];

// Fetch CMS data with fallback
const { data: cmsTestimonials } = await getFeaturedTestimonials();
const { data: cmsPrograms } = await getFeaturedPrograms();
const { data: cmsNews } = await getNews({ sort: ['published_at:desc'], pageSize: 3 });
---

<Layout>
  <Header />

  <main class="min-h-screen bg-white">
    <EnhancedHero
      title={cerinHome.hero.title}
      subtitle={cerinHome.hero.subtitle}
      ctaText1={cerinHome.hero.cta[0]}
      ctaText2={cerinHome.hero.cta[1]}
      image={cerinHome.images.graduates}
    />

    <TrustStatsSection stats={trustStatsData} />

    <TestimonialCarousel
      testimonials={(cmsTestimonials || []).map((t) => ({
        id: t.id,
        name: t.name,
        role: t.role,
        quote: t.quote,
        image: typeof t.image === 'object' && t.image ? t.image.url : undefined,
        featured: t.featured,
      }))}
    />

    <section class="py-20 bg-white border-t border-gray-100">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <span class="inline-block px-4 py-1.5 rounded-full text-xs font-semibold mb-4" style={{ background: "#F0FAF0", color: G }}>
            Nos Pôles de Formation
          </span>
          <h2 class="text-3xl md:text-4xl font-extrabold text-gray-900 mb-4" style={{ fontFamily: "'Poppins', sans-serif" }}>
            Un parcours complet, du collège au supérieur
          </h2>
        </div>
        <div class="grid md:grid-cols-3 gap-8">
          {cerinHome.poles.map((pole) => {
            const IconComponent = pole.icon === "GraduationCap" ? GraduationCap : pole.icon === "Wrench" ? Wrench : BookOpen;
            return (
              <div class="p-8 rounded-3xl hover:shadow-xl transition-all duration-300 hover:-translate-y-2 bg-white" style={{ boxShadow: "0 4px 16px rgba(0,0,0,0.05)" }}>
                <div class="w-16 h-16 rounded-2xl flex items-center justify-center mb-6" style={{ background: G + "20" }}>
                  <IconComponent size={32} style={{ color: G }} />
                </div>
                <h3 class="text-xl font-bold text-gray-900 mb-4" style={{ fontFamily: "'Poppins', sans-serif" }}>{pole.title}</h3>
                <ul class="space-y-3">
                  {pole.items.map((item) => (
                    <li class="flex items-center gap-3 text-sm text-gray-600" style={{ fontFamily: "'Inter', sans-serif" }}>
                      <div class="w-2 h-2 rounded-full" style={{ background: G }} />
                      {item}
                    </li>
                  ))}
                </ul>
                {(pole.title === "Enseignement Supérieur" || pole.title === "Technique & Professionnel") && (
                  <a href="/formations/enseignement-superieur" class="inline-flex items-center gap-2 mt-6 px-4 py-2 rounded-xl text-xs font-bold" style={{ background: "#F0FAF0", color: G }}>
                    Voir les formations <span style={{ fontFamily: "'Poppins', sans-serif" }}>→</span>
                  </a>
                )}
              </div>
            );
          })}
        </div>
      </div>
    </section>

    <section class="py-20" style={{ background: BG }}>
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <span class="inline-block px-4 py-1.5 rounded-full text-xs font-semibold mb-4" style={{ background: "white", color: G }}>
            Formations mises en avant
          </span>
          <h2 class="text-3xl md:text-4xl font-extrabold text-gray-900 mb-4" style={{ fontFamily: "'Poppins', sans-serif" }}>
            Découvrez nos programmes
          </h2>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
          {(cmsPrograms || []).slice(0, 4).map((program: any) => (
            <a href={`/formations/enseignement-superieur`} class="block p-6 rounded-2xl bg-white hover:shadow-lg transition-all border border-gray-100" style={{ boxShadow: "0 4px 16px rgba(0,0,0,0.05)" }}>
              {program.image && typeof program.image === 'object' && program.image.url && (
                <img src={program.image.url} alt={program.title} class="w-full h-40 object-cover rounded-xl mb-4" onerror="this.src='/images/placeholder.svg'; this.onerror=null;" />
              )}
              <h3 class="font-bold text-gray-900 mb-2" style={{ fontFamily: "'Poppins', sans-serif" }}>{program.title}</h3>
              <p class="text-xs text-gray-500 mb-2" style={{ fontFamily: "'Inter', sans-serif" }}>{program.level} • {program.duration}</p>
              <p class="text-xs text-gray-600 line-clamp-2" style={{ fontFamily: "'Inter', sans-serif" }}>{program.description}</p>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="py-20 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <span class="inline-block px-4 py-1.5 rounded-full text-xs font-semibold mb-4" style={{ background: "#F0FAF0", color: G }}>
            Actualités récentes
          </span>
          <h2 class="text-3xl md:text-4xl font-extrabold text-gray-900 mb-4" style={{ fontFamily: "'Poppins', sans-serif" }}>
            Dernières nouvelles du CERIN
          </h2>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {(cmsNews || []).map((article: any) => (
            <article class="bg-white rounded-2xl overflow-hidden border border-gray-100 hover:shadow-lg transition-shadow" style={{ boxShadow: "0 4px 16px rgba(0,0,0,0.05)" }}>
              {article.image && typeof article.image === 'object' && article.image.url && (
                <img src={article.image.url} alt={article.title} class="w-full h-48 object-cover" onerror="this.src='/images/placeholder.svg'; this.onerror=null;" />
              )}
              <div class="p-6">
                <span class="inline-block px-2 py-1 rounded-full text-xs font-semibold mb-2" style={{ background: "#F0FAF0", color: G }}>{article.category}</span>
                <h3 class="font-bold text-gray-900 mb-2" style={{ fontFamily: "'Poppins', sans-serif" }}>{article.title}</h3>
                <p class="text-xs text-gray-500 mb-3" style={{ fontFamily: "'Inter', sans-serif" }}>{article.excerpt}</p>
                <time class="text-xs text-gray-400" datetime={article.published_at}>
                  {new Date(article.published_at).toLocaleDateString('fr-FR', { year: 'numeric', month: 'long', day: 'numeric' })}
                </time>
              </div>
            </article>
          ))}
        </div>
        <div class="text-center mt-10">
          <a href="/actualites" class="inline-flex items-center gap-2 px-6 py-3 rounded-xl font-bold text-sm text-white" style={{ background: G, fontFamily: "'Poppins', sans-serif" }}>
            Voir toutes les actualités <span>→</span>
          </a>
        </div>
      </div>
    </section>

    <FinalCtaBanner
      title="Prêt à construire votre avenir ?"
      subtitle="Rejoignez le Groupe CERIN et donnez-vous toutes les chances de réussir."
    />
  </main>

  <Footer />
</Layout>
