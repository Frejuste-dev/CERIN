---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<Layout>
  <Header />
  <main class="pt-20">
    <div class="py-32 text-center max-w-xl mx-auto px-4">
      <h1 class="text-8xl font-black text-[#7AC943] mb-4 font-['Poppins',sans-serif]">404</h1>
      <h2 class="text-2xl font-bold text-gray-900 mb-4 font-['Poppins',sans-serif]">Page Non Trouvée</h2>
      <p class="text-gray-500 mb-8 font-['Inter',sans-serif]">La page que vous cherchez n'existe pas ou a été déplacée.</p>
      <a href="/" class="inline-flex items-center justify-center px-6 py-3 rounded-xl font-bold text-sm text-white transition-all hover:scale-105 bg-[#7AC943] font-['Poppins',sans-serif]">
        Retour à l'accueil
      </a>
    </div>
  </main>
  <Footer />
</Layout>
