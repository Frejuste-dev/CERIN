---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import PageHero from "../components/shared/PageHero.astro";
import { GraduationCap, Wrench, Briefcase, Award, BookOpen, Target, Shield, Users, Handshake } from "lucide-react";
import { getPrograms, getFeaturedTestimonials } from "../lib/content";

const G = "#7AC943";
const Y = "#F4D000";
const BG = "#F5F6F8";
const DARK = "#0F2010";

const values = [
  { icon: Target, title: "Excellence", desc: "Nous visons les plus hauts standards académiques et pédagogiques dans tout ce que nous faisons.", color: G, bg: "#F0FAF0" },
  { icon: Shield, title: "Intégrité", desc: "Transparence, honnêteté et éthique guident chacune de nos décisions et interactions.", color: G, bg: "#F0FAF0" },
  { icon: Handshake, title: "Respect", desc: "Chaque personne est traitée avec dignité. L'écoute et la tolérance sont au cœur de nos relations.", color: Y, bg: "#FFF8CC" },
  { icon: Users, title: "Travail d'équipe", desc: "Ensemble nous sommes plus forts. La coopération et l'entraide sont essentielles pour réussir.", color: Y, bg: "#FFF8CC" },
];

const programs = [
  { icon: BookOpen, title: "Enseignement Général", desc: "Du collège au lycée, un solide socle académique pour préparer le baccalauréat.", color: G },
  { icon: Wrench, title: "Enseignement Technique", desc: "Formations pratiques et professionnalisantes pour intégrer le marché du travail.", color: G },
  { icon: Briefcase, title: "Formation Professionnelle", desc: "Des cursus adaptés aux métiers en demande pour une insertion rapide.", color: Y },
  { icon: Award, title: "Formation Qualifiante", desc: "Des certifications reconnues pour booster votre carrière professionnelle.", color: G },
  { icon: GraduationCap, title: "Enseignement Supérieur", desc: "BTS, Licence, Master — des diplômes reconnus par l'État pour construire votre avenir.", color: G },
];

// Fetch CMS data (with automatic fallback to mock data)
const { data: cmsPrograms } = await getPrograms({
  filters: { category: { $eq: "SUPERIEUR" } },
  populate: '*',
  sort: ['title:asc'],
});

const { data: cmsTestimonials } = await getFeaturedTestimonials();
---

<Layout title="À propos – Groupe CERIN">
  <Header />

  <main class="pt-20">
    <PageHero
      title="Qui Sommes-Nous"
      subtitle="Un établissement d'enseignement renommé en Côte d'Ivoire. Découvrez l'histoire, les valeurs, les programmes et les réussites du Groupe CERIN."
      image="https://images.unsplash.com/photo-1541339907198-e08756dedf3f?auto=format&fit=crop&w=1200&q=80"
      breadcrumbs={[{ label: "À propos" }]}
      accent={G}
    />

    <!-- Introduction -->
    <section class="py-20 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid lg:grid-cols-2 gap-12 items-center">
          <div>
            <span class="inline-block px-4 py-1.5 rounded-full text-xs font-semibold mb-5" style={{ background: "#F0FAF0", color: G }}>
              Le Groupe CERIN
            </span>
            <h2 class="text-3xl md:text-4xl font-extrabold text-gray-900 mb-6" style={{ fontFamily: "'Poppins', sans-serif" }}>
              Formation d'excellence de la Maternelle au Master
            </h2>
            <p class="text-gray-600 leading-relaxed mb-6" style={{ fontFamily: "'Inter', sans-serif" }}>
              Le Groupe CERIN est une école située à proximité de l'Institut Pasteur de Yopougon. Nous proposons tous les cycles d'enseignement, de la Maternelle jusqu'au Master, pour former des leaders de demain.
            </p>
            <div class="space-y-3">
              {["Enseignement Général", "Enseignement Technique", "Formation Professionnelle", "Formation Qualifiante", "Enseignement Supérieur"].map((cycle) => (
                <div class="flex items-center gap-3">
                  <div class="w-6 h-6 rounded-full flex items-center justify-center shrink-0" style={{ background: "#F0FAF0" }}>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke={G} strokeWidth="3" strokeLinecap="round" strokeLinejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                  </div>
                  <span class="text-sm font-semibold text-gray-700" style={{ fontFamily: "'Inter', sans-serif" }}>{cycle}</span>
                </div>
              ))}
            </div>
            <div class="mt-8 p-5 rounded-2xl" style={{ background: BG, border: "1px solid #E5E7EB" }}>
              <p class="text-lg font-black text-center" style={{ fontFamily: "'Poppins', sans-serif", color: DARK }}>
                GROUPE CERIN — POUR VOTRE FORMATION, SOYEZ CERIN
              </p>
            </div>
          </div>
          <div class="relative">
            <img
              src="https://images.unsplash.com/photo-1523050854058-8df90110c9f1?auto=format&fit=crop&w=800&q=80"
              alt="Campus du Groupe CERIN à Yopougon"
              class="w-full rounded-3xl object-cover"
              style={{ height: "420px", boxShadow: "0 16px 48px rgba(0,0,0,0.12)" }}
              onerror="this.src='/images/placeholder.svg'; this.onerror=null;"
            />
            <div class="absolute -bottom-4 -left-4 bg-white rounded-2xl px-5 py-4 shadow-xl" style={{ border: "1px solid #E5E7EB" }}>
              <p class="font-black text-2xl" style={{ fontFamily: "'Poppins', sans-serif", color: G }}>10+</p>
              <p class="text-xs font-semibold text-gray-600" style={{ fontFamily: "'Inter', sans-serif" }}>Années d'excellence</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- History Section -->
    <section class="py-20" style={{ background: BG }}>
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-14">
          <span class="inline-block px-4 py-1.5 rounded-full text-xs font-semibold mb-4" style={{ background: "white", color: G }}>
            Notre Histoire
          </span>
          <h2 class="text-3xl md:text-4xl font-extrabold text-gray-900 mb-4" style={{ fontFamily: "'Poppins', sans-serif" }}>
            Plus de 10 ans au service de l'éducation
          </h2>
          <p class="text-gray-600 max-w-2xl mx-auto" style={{ fontFamily: "'Inter', sans-serif" }}>
            Créé en 2014, le Groupe CERIN incarne le professionnalisme et l'engagement envers l'éducation de qualité en Côte d'Ivoire.
          </p>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-5 gap-5">
          {[
            { year: "2014", title: "Création du Groupe CERIN", desc: "Fondation de l'établissement near Institut Pasteur de Yopougon avec une vision d'excellence." },
            { year: "2016", title: "Ouverture de l'Enseignement Technique", desc: "Lancement des filières techniques et professionnelles pour répondre aux besoins du marché." },
            { year: "2018", title: "Lancement de l'Enseignement Supérieur", desc: "Ouverture des programmes de BTS, Licence et Master pour former les cadres de demain." },
            { year: "2020", title: "Formation Qualifiante", desc: "Mise en place de programmes qualifiants pour un accès rapide à l'emploi." },
            { year: "2024", title: "10 ans d'excellence", desc: "Plus d'une décennie au service de l'éducation, avec des milliers de diplômés." },
          ].map((item) => (
            <div class="relative bg-white p-6 rounded-2xl border border-gray-100 hover:shadow-lg transition-all group" style={{ boxShadow: "0 4px 16px rgba(0,0,0,0.04)" }}>
              <div class="w-10 h-10 rounded-xl flex items-center justify-center mb-4 transition-transform group-hover:scale-110" style={{ background: "#F0FAF0" }}>
                <span class="text-sm font-black" style={{ color: G, fontFamily: "'Poppins', sans-serif" }}>{item.year.slice(2)}</span>
              </div>
              <span class="inline-block px-2 py-0.5 rounded text-xs font-bold mb-2" style={{ background: "#F0FAF0", color: G }}>{item.year}</span>
              <h3 class="font-bold text-gray-900 mb-2 text-sm" style={{ fontFamily: "'Poppins', sans-serif" }}>{item.title}</h3>
              <p class="text-xs text-gray-500 leading-relaxed" style={{ fontFamily: "'Inter', sans-serif" }}>{item.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Mission Section -->
    <section class="py-20 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid lg:grid-cols-2 gap-8">
          <div class="p-8 md:p-10 rounded-3xl border-2" style={{ borderColor: G + "30", background: "#F0FAF0" }}>
            <div class="w-14 h-14 rounded-2xl flex items-center justify-center mb-5" style={{ background: "rgba(122,201,67,0.15)" }}>
              <Target size={26} style={{ color: G }} />
            </div>
            <h3 class="font-black text-gray-900 text-xl mb-4" style={{ fontFamily: "'Poppins', sans-serif" }}>Notre Mission</h3>
            <p class="text-gray-600 leading-relaxed mb-4" style={{ fontFamily: "'Inter', sans-serif" }}>
              Le Groupe CERIN est dédié à fournir une éducation de haut niveau à ses élèves et étudiants. Notre mission est de former des individus bien équilibrés, prêts à relever les défis du monde moderne.
            </p>
            <ul class="space-y-2">
              {["Offrir une éducation de qualité", "Former des citoyens responsables", "Préparer les étudiants à l'avenir"].map((item) => (
                <li class="flex items-start gap-2 text-sm text-gray-700" style={{ fontFamily: "'Inter', sans-serif" }}>
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke={G} strokeWidth="3" strokeLinecap="round" strokeLinejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                  {item}
                </li>
              ))}
            </ul>
          </div>

          <div class="p-8 md:p-10 rounded-3xl border-2" style={{ borderColor: Y + "30", background: "#FFF8CC" }}>
            <div class="w-14 h-14 rounded-2xl flex items-center justify-center mb-5" style={{ background: "rgba(244,208,0,0.2)" }}>
              <Shield size={26} style={{ color: DARK }} />
            </div>
            <h3 class="font-black text-gray-900 text-xl mb-4" style={{ fontFamily: "'Poppins', sans-serif" }}>Nos Valeurs</h3>
            <p class="text-gray-600 leading-relaxed mb-4" style={{ fontFamily: "'Inter', sans-serif" }}>
              Ces valeurs fondamentales guident toutes nos actions et constituent le cœur de notre identité.
            </p>
            <div class="grid grid-cols-2 gap-3">
              {values.map((v) => {
                const Icon = v.icon;
                return (
                  <div class="flex items-start gap-2">
                    <div class="w-6 h-6 rounded-full flex items-center justify-center shrink-0 mt-0.5" style={{ background: v.bg }}>
                      <Icon size={12} style={{ color: v.color }} />
                    </div>
                    <span class="text-sm font-bold text-gray-800" style={{ fontFamily: "'Poppins', sans-serif" }}>{v.title}</span>
                  </div>
                );
              })}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Values Cards Section -->
    <section class="py-20" style={{ background: BG }}>
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <span class="inline-block px-4 py-1.5 rounded-full text-xs font-semibold mb-4" style={{ background: "white", color: G }}>
            Ce qui nous anime
          </span>
          <h2 class="text-3xl md:text-4xl font-extrabold text-gray-900" style={{ fontFamily: "'Poppins', sans-serif" }}>
            Nos valeurs en action
          </h2>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
          {values.map((v) => {
            const Icon = v.icon;
            return (
              <div class="bg-white p-6 rounded-2xl text-center hover:-translate-y-1 hover:shadow-xl transition-all duration-300 border border-gray-100" style={{ boxShadow: "0 4px 16px rgba(0,0,0,0.04)" }}>
                <div class="w-14 h-14 rounded-2xl flex items-center justify-center mx-auto mb-4" style={{ background: v.bg }}>
                  <Icon size={26} style={{ color: v.color }} />
                </div>
                <h3 class="font-bold text-gray-900 mb-2" style={{ fontFamily: "'Poppins', sans-serif" }}>{v.title}</h3>
                <p class="text-xs text-gray-500 leading-relaxed" style={{ fontFamily: "'Inter', sans-serif" }}>{v.desc}</p>
              </div>
            );
          })}
        </div>
      </div>
    </section>

    <!-- Programmes Section -->
    <section class="py-20 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-14">
          <span class="inline-block px-4 py-1.5 rounded-full text-xs font-semibold mb-4" style={{ background: "#F0FAF0", color: G }}>
            Nos Programmes
          </span>
          <h2 class="text-3xl md:text-4xl font-extrabold text-gray-900 mb-4" style={{ fontFamily: "'Poppins', sans-serif" }}>
            Un parcours complet, de la Maternelle au Master
          </h2>
          <p class="text-gray-600 max-w-2xl mx-auto" style={{ fontFamily: "'Inter', sans-serif" }}>
            Nous proposons une large gamme de programmes d'études adaptés à tous les niveaux et à tous les intérêts.
          </p>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-5 gap-5">
          {programs.map((p) => {
            const Icon = p.icon;
            return (
              <div class="group p-6 rounded-2xl border border-gray-100 hover:shadow-xl transition-all duration-300 hover:-translate-y-1 bg-white" style={{ boxShadow: "0 4px 16px rgba(0,0,0,0.04)" }}>
                <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-4 transition-transform group-hover:scale-110" style={{ background: p.color === Y ? "#FFF8CC" : "#F0FAF0" }}>
                  <Icon size={22} style={{ color: p.color }} />
                </div>
                <h3 class="font-bold text-gray-900 mb-2 text-sm" style={{ fontFamily: "'Poppins', sans-serif" }}>{p.title}</h3>
                <p class="text-xs text-gray-500 leading-relaxed" style={{ fontFamily: "'Inter', sans-serif" }}>{p.desc}</p>
              </div>
            );
          })}
        </div>

        {(cmsPrograms?.length || 0) > 0 && (
          <div class="mt-12">
            <h3 class="text-2xl font-extrabold text-gray-900 mb-6 text-center" style={{ fontFamily: "'Poppins', sans-serif" }}>
              Formations supérieures disponibles
            </h3>
            <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
              {(cmsPrograms || []).slice(0, 4).map((program: any) => (
                <a href="/formations/enseignement-superieur" class="block p-6 rounded-2xl bg-white hover:shadow-lg transition-all border border-gray-100" style={{ boxShadow: "0 4px 16px rgba(0,0,0,0.05)" }}>
                  {program.image && typeof program.image === 'object' && program.image.url && (
                    <img src={program.image.url} alt={program.title} class="w-full h-40 object-cover rounded-xl mb-4" onerror="this.src='/images/placeholder.svg'; this.onerror=null;" />
                  )}
                  <h4 class="font-bold text-gray-900 mb-1" style={{ fontFamily: "'Poppins', sans-serif" }}>{program.title}</h4>
                  <p class="text-xs text-gray-500" style={{ fontFamily: "'Inter', sans-serif" }}>{program.level} • {program.duration}</p>
                </a>
              ))}
            </div>
          </div>
        )}
      </div>
    </section>

    <!-- Director Section -->
    <section class="py-20" style={{ background: BG }}>
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid lg:grid-cols-2 gap-12 items-center">
          <div class="relative">
            <img
              src="https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?auto=format&fit=crop&w=600&q=80"
              alt="Direction du Groupe CERIN"
              class="w-full rounded-3xl object-cover"
              style={{ height: "420px", boxShadow: "0 16px 48px rgba(0,0,0,0.12)" }}
              onerror="this.src='/images/placeholder.svg'; this.onerror=null;"
            />
          </div>
          <div>
            <span class="inline-block px-4 py-1.5 rounded-full text-xs font-semibold mb-5" style={{ background: "#F0FAF0", color: G }}>
              Message de la Direction
            </span>
            <h2 class="text-gray-900 mb-5 font-extrabold text-3xl" style={{ fontFamily: "'Poppins', sans-serif" }}>
              "Former des leaders de demain"
            </h2>
            <p class="text-gray-600 leading-relaxed mb-5" style={{ fontFamily: "'Inter', sans-serif" }}>
              Depuis 2014, le Groupe CERIN s'engage à fournir une éducation de haut niveau. Notre mission est de former des individus bien équilibrés, prêts à relever les défis du monde moderne.
            </p>
            <p class="text-gray-600 leading-relaxed mb-6" style={{ fontFamily: "'Inter', sans-serif" }}>
              Nos valeurs d'Excellence, d'Intégrité, de Respect et de Travail d'équipe guident chacune de nos actions. Au Groupe CERIN, nous croyons que chaque étudiant a le potentiel de devenir un leader qui compte.
            </p>
            <div class="inline-flex items-center gap-3 p-4 rounded-2xl" style={{ background: "white", border: "1px solid #E5E7EB" }}>
              <div class="w-10 h-10 rounded-xl flex items-center justify-center" style={{ background: "#F0FAF0" }}>
                <GraduationCap size={20} style={{ color: G }} />
              </div>
              <div>
                <p class="font-black text-sm text-gray-900" style={{ fontFamily: "'Poppins', sans-serif" }}>Direction Pédagogique</p>
                <p class="text-xs text-gray-500" style={{ fontFamily: "'Inter', sans-serif" }}>Groupe CERIN — Yopougon Songon</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="py-16 bg-white">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <div class="p-8 md:p-12 rounded-3xl" style={{ background: "linear-gradient(135deg, #0F2010, #1A3A1A)", boxShadow: "0 16px 48px rgba(0,0,0,0.15)" }}>
          <h2 class="text-white text-3xl md:text-4xl font-black mb-4" style={{ fontFamily: "'Poppins', sans-serif" }}>
            Prêt à rejoindre le Groupe CERIN ?
          </h2>
          <p class="text-green-200 mb-8 max-w-xl mx-auto" style={{ fontFamily: "'Inter', sans-serif" }}>
            Inscrivez-vous dès maintenant et bénéficiez d'une éducation de qualité, de la Maternelle au Master. Soyez CERIN !
          </p>
          <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
            <a href="/admissions" class="inline-flex items-center gap-2 px-8 py-4 rounded-xl font-bold text-base text-white transition-all hover:shadow-xl hover:-translate-y-0.5" style={{ background: G, fontFamily: "'Poppins', sans-serif" }}>
              Je m'inscris
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2.5" strokeLinecap="round" strokeLinejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
            <a href="/contact" class="inline-flex items-center gap-2 px-8 py-4 rounded-xl font-bold text-base border-2 border-white/30 text-white transition-all hover:bg-white/10" style={{ fontFamily: "'Poppins', sans-serif" }}>
              Nous contacter
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
