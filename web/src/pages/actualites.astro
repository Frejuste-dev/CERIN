---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import PageHero from "../components/shared/PageHero.astro";
import { NewsSection } from "../components/NewsSection";
import { getNews } from "../lib/content";

const G = "#7AC943";

const { data: articles } = await getNews({
  sort: ['published_at:desc'],
  populate: '*',
});
---

<Layout>
  <Header />

  <main class="pt-20">
    <PageHero
      title="Actualités & Événements"
      subtitle="Suivez toute la vie du Groupe CERIN : réussites, partenariats, événements et annonces."
      image="https://images.unsplash.com/photo-1523050854058-8df90110c9f1?auto=format&fit=crop&w=1200&q=80"
      breadcrumbs={[{ label: "Actualités" }]}
      accent={G}
    />

    <NewsSection client:load articles={articles || []} />
  </main>

  <Footer />
</Layout>
